#!/bin/sh
#
# doorbell_alarm – Doorbell chime LED indicator
#
# When chimes are paired, lights the indicator LED:
#   blue  = day mode
#   yellow = night mode
# When no chimes are paired, flashes alternating blue/yellow alarm.
# Monitors /tmp/nightmode.txt for mode changes.
#
# Run at boot via S14doorbell-alarm.
#

CONFIG="/etc/thingino.json"
PIDFILE="/run/doorbell_alarm.pid"
NIGHTMODE="/tmp/nightmode.txt"

[ -x /usr/sbin/doorbell_ctrl ] || exit 0

# Kill stale instance
[ -f "$PIDFILE" ] && kill "$(cat "$PIDFILE")" 2>/dev/null
rm -f "$PIDFILE"
echo $$ >"$PIDFILE"

last_mode=""

while true; do
	have_chimes=0
	doorbell_ctrl list 2>/dev/null | grep -q '^ ' && have_chimes=1

	MODE="day"
	if [ -f "$NIGHTMODE" ]; then
		MODE=$(cat "$NIGHTMODE" 2>/dev/null)
	fi
	[ -z "$MODE" ] && MODE="day"

	if [ "$have_chimes" -eq 0 ]; then
		# No chimes — flash alarm
		logger -t doorbell_alarm "No chimes paired – signaling alarm"
		while true; do
			if doorbell_ctrl list 2>/dev/null | grep -q '^ '; then
				break
			fi
			led b 2>/dev/null
			sleep 0.8
			led off 2>/dev/null
			sleep 0.2
			led y 2>/dev/null
			sleep 0.8
			led off 2>/dev/null
			sleep 0.2
		done
		last_mode=""
		continue
	fi

	# Chimes present — steady LED, update on mode change
	if [ "$MODE" != "$last_mode" ]; then
		if [ "$MODE" = "night" ]; then
			led y 2>/dev/null
		else
			led b 2>/dev/null
		fi
		last_mode="$MODE"
	fi

	sleep 5
done
