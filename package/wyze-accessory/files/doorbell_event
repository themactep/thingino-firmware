#!/bin/sh
#
# doorbell_event – Event-driven chime dispatcher for Thingino
#
# Reads chime.events configuration from /etc/thingino.json, determines
# day/night state from /tmp/nightmode.txt, dispatches the chime, and
# controls the indicator LED (blue = day, yellow = night, brief blink
# on event to confirm ringing).
#
# Usage: doorbell_event <event_name>
#
# thingino.json schema (chime.events section, per-period format):
#   "chime": {
#     "events": {
#       "<event>": {
#         "day":   { "sound":"...", "volume":"5", "repeat":"2", "group":"..." },
#         "night": { "sound":"...", "volume":"2", "repeat":"1", "group":"..." }
#       }
#     }
#   }
#
# Each period (day/night) has its own complete set of parameters.
# Nothing is shared between them.
#

CONFIG="/etc/thingino.json"
NIGHTMODE="/tmp/nightmode.txt"

[ $# -ge 1 ] || {
	echo "Usage: $0 <event_name>" >&2
	exit 1
}
EVENT="$1"

MODE="day"
if [ -f "$NIGHTMODE" ]; then
	MODE=$(cat "$NIGHTMODE" 2>/dev/null)
fi
[ -z "$MODE" ] && MODE="day"

jctval() {
	local val
	val=$(jct "$CONFIG" get "$1" 2>/dev/null | tr -d '"')
	if [ "$val" = "null" ] || [ "$val" = "NULL" ]; then
		echo ""
	else
		echo "$val"
	fi
}

# Per-period fields
sound=$(jctval "chime.events.$EVENT.$MODE.sound")
volume=$(jctval "chime.events.$EVENT.$MODE.volume")
repeat=$(jctval "chime.events.$EVENT.$MODE.repeat")
group=$(jctval "chime.events.$EVENT.$MODE.group")

[ -z "$sound" ] && {
	echo "doorbell_event: no sound for event '$EVENT' in $MODE mode" >&2
	exit 2
}

# Set steady LED: blue for day, yellow for night
if [ "$MODE" = "night" ]; then
	led y 2>/dev/null
	LED_COLOR=y
else
	led b 2>/dev/null
	LED_COLOR=b
fi

# Brief blink to confirm the event
sleep 0.15
led off 2>/dev/null
sleep 0.15
led "$LED_COLOR" 2>/dev/null

# Build and execute command
set -- doorbell_ctrl
if [ -n "$group" ]; then
	set -- "$@" play-group "$group"
else
	set -- "$@" play-all
fi
set -- "$@" "$sound"
[ -n "$volume" ] && set -- "$@" "$volume"
[ -n "$repeat" ] && set -- "$@" "$repeat"

echo "[doorbell_event] $EVENT ($MODE) → $*"
exec "$@"
