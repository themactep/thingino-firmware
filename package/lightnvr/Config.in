config BR2_PACKAGE_LIGHTNVR
	bool "lightnvr"
	depends on BR2_TOOLCHAIN_HEADERS_AT_LEAST_4_4
	select BR2_PACKAGE_GO2RTC
	select BR2_PACKAGE_HOST_NODEJS
	select BR2_PACKAGE_THINGINO_FFMPEG
	select BR2_PACKAGE_SQLITE
	select BR2_PACKAGE_CJSON
	default n
	help
	  Experimental NVR for Ingenic SoC's.
	  Automatically enables FFmpeg with staging installation
	  and required libraries for CMake-based builds.
