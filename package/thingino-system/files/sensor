#!/bin/sh

sensor_root="/proc/jz/sensor"

[ -d "$sensor_root" ] || { echo "$sensor_root does not exist."; exit 1; }

param="${1:-all}"
idx="${2:-0}"
sensor_dir="$sensor_root/sensor$idx"

case "$param" in
	count)
		cat "$sensor_root/count"
		;;
	all | -a)
		[ -d "$sensor_dir" ] || { echo "sensor$idx is not registered."; exit 1; }
		for f in "$sensor_dir"/*; do
			printf '%-16s %s\n' "$(basename "$f"):" "$(cat "$f")"
		done
		;;
	*)
		if [ -e "$sensor_dir/$param" ]; then
			cat "$sensor_dir/$param"
		else
			echo "Usage: $0 [all|count|<param>] [sensor_index]"
			[ -d "$sensor_dir" ] && echo "Params: $(ls "$sensor_dir" | tr '\n' ' ')"
			exit 1
		fi
		;;
esac
