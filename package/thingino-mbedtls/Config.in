config BR2_PACKAGE_THINGINO_MBEDTLS
	bool "mbedTLS with HTTP/2 support"
	select BR2_PACKAGE_MBEDTLS
	help
	  Mbed TLS is an open-source cryptographic library that provides
	  SSL and TLS functionality. This version includes HTTP/2-capable
	  configuration with ALPN, SNI, Session Tickets, and TLS 1.3 ciphers.

	  https://tls.mbed.org/

config BR2_PACKAGE_THINGINO_MBEDTLS_JZ_CRYPTO_ALT
	bool "Ingenic hardware AES acceleration"
	depends on BR2_PACKAGE_THINGINO_MBEDTLS
	help
	  Replace the software AES, CCM and GCM implementations with
	  hardware-accelerated versions that use the Ingenic T-series
	  AES engine via /dev/aes. Requires the jz-aes kernel module.