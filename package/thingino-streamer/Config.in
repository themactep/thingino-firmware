config BR2_PACKAGE_THINGINO_STREAMER
	bool

choice
	prompt "Streamer"
	default BR2_PACKAGE_THINGINO_STREAMER_NONE if BR2_THINGINO_TOOLCHAIN
	default BR2_PACKAGE_THINGINO_STREAMER_PRUDYNT if !BR2_SOC_FAMILY = "a1"
	help
	  Select the camera streamer to use.

config BR2_PACKAGE_THINGINO_STREAMER_PRUDYNT
	bool "Prudynt-T"
	depends on !BR2_SOC_FAMILY = "a1"
	select BR2_PACKAGE_PRUDYNT_T
	select BR2_PACKAGE_THINGINO_STREAMER
	help
	  Traditional monolithic streamer.

config BR2_PACKAGE_THINGINO_STREAMER_RAPTOR
	bool "Raptor Streaming System"
	depends on !BR2_SOC_FAMILY = "a1"
	select BR2_PACKAGE_THINGINO_RAPTOR
	select BR2_PACKAGE_THINGINO_STREAMER
	help
	  Modular microservice streamer (RSS).

config BR2_PACKAGE_THINGINO_STREAMER_STRERO
	bool "Strero"
	depends on !BR2_SOC_FAMILY = "a1"
	select BR2_PACKAGE_STRERO
	select BR2_PACKAGE_THINGINO_STREAMER
	help
	  Strero streaming stack.

config BR2_PACKAGE_THINGINO_STREAMER_NONE
	bool "None"
	help
	  No streamer.

endchoice

if BR2_PACKAGE_THINGINO_STREAMER
source "$BR2_EXTERNAL_THINGINO_PATH/package/prudynt-t/Config.in"
source "$BR2_EXTERNAL_THINGINO_PATH/package/thingino-raptor/Config.in"
source "$BR2_EXTERNAL_THINGINO_PATH/package/strero/Config.in"

endif
