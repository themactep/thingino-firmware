config BR2_PACKAGE_INGENIC_SYSTEM_LIBS_NEO
	bool "ingenic-system-libs-neo (replaces stock libalog + libsysutils)"
	depends on BR2_PACKAGE_INGENIC_LIB
	help
	  Open-source drop-in replacements for Ingenic SDK
	  libalog.so and libsysutils.so. Thread-safe, 51% smaller.
	  Overrides the stock blobs when selected.

	  https://github.com/gtxaspec/ingenic-system-libs-neo

if BR2_PACKAGE_INGENIC_SYSTEM_LIBS_NEO

config BR2_PACKAGE_INGENIC_SYSTEM_LIBS_NEO_LIBALOG
	bool "libalog (replaces stock libalog.so)"
	default y
	help
	  Open-source drop-in replacement for Ingenic libalog.so.

config BR2_PACKAGE_INGENIC_SYSTEM_LIBS_NEO_LIBSYSUTILS
	bool "libsysutils (replaces stock libsysutils.so)"
	default n
	help
	  Open-source drop-in replacement for Ingenic libsysutils.so.

endif
