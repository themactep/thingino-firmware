#!/bin/sh

DAEMON="dusk2dawn"
PRUDYNT_CONFIG="/etc/prudynt.json"
CRONTABS_FLASH="/etc/cron/crontabs/root"
CRONTABS_RAM="/run/cron/crontabs/root"

. /usr/share/common

# Override CRONTABS from common to point at tmpfs copy
CRONTABS="$CRONTABS_RAM"

sun_enabled() {
	[ "$(jct "$PRUDYNT_CONFIG" get daynight.sun.enabled 2>/dev/null)" = "true" ]
}

ensure_ram_crontab() {
	mkdir -p "$(dirname "$CRONTABS_RAM")"
	# Seed from flash if the RAM copy doesn't exist yet
	if [ ! -f "$CRONTABS_RAM" ]; then
		cp "$CRONTABS_FLASH" "$CRONTABS_RAM" 2>/dev/null || touch "$CRONTABS_RAM"
		chmod 600 "$CRONTABS_RAM"
		echo_info "Crontab seeded from flash to RAM"
	fi
}

start() {
	echo_title "Starting $DAEMON"

	ensure_ram_crontab

	if ! sun_enabled; then
		echo_info "Sun tracking disabled in config, skipping"
		return 0
	fi

	# Add nightly refresh cron entry if not already present
	if grep -q "$DAEMON" "$CRONTABS_RAM" 2>/dev/null; then
		echo_info "$DAEMON already in crontab"
	else
		printf "# run %s nightly at 0:00 to refresh tomorrow's times\n0 0 * * * %s\n" \
			"$DAEMON" "$DAEMON" >> "$CRONTABS_RAM"
		echo_info "$DAEMON added to crontab"
	fi

	# Calculate and set today's sunrise/sunset cron entries immediately
	echo_info "Calculating today's sunrise/sunset times..."
	/usr/sbin/$DAEMON
}

stop() {
	echo_title "Stopping $DAEMON"
	# Remove all dusk2dawn-managed cron entries from RAM crontab
	if [ -f "$CRONTABS_RAM" ]; then
		tmpfile=$(mktemp)
		sed '/dusk2dawn/d;/autogenerated/,+1d' "$CRONTABS_RAM" > "$tmpfile"
		cp "$tmpfile" "$CRONTABS_RAM"
		rm -f "$tmpfile"
		echo_info "Removed $DAEMON cron entries"
	fi
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		stop
		start
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
		;;
esac

exit 0
