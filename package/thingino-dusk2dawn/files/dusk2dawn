#!/bin/sh

. /usr/share/common

# Exit early if paranoid mode is enabled (no internet access)
if [ "$(jct "$CONFIG_JSON" get webui.paranoid 2>/dev/null)" = "true" ]; then
	echo_info "Paranoid mode enabled, skipping (no internet access)"
	exit 0
fi

PRUDYNT_CONFIG="/etc/prudynt.json"
API_URL="https://api.sunrise-sunset.org/json"
API_DATA_FILE="/tmp/sunrise-sunset.tmp"
# Write cron entries to tmpfs — no flash writes
CRONTABS="/run/cron/crontabs/root"
SR_MARK="# switch to day mode at sunrise (autogenerated)"
SS_MARK="# switch to night mode at sunset (autogenerated)"

show_help() {
	echo "Usage: $0 [params]
Where:
	-x coord    Latitude (overrides config).
	-y coord    Longitude (overrides config).
	-r offset   Offset at sunRise in minutes (overrides config).
	-s offset   Offset at sunSet in minutes (overrides config).
	-d date     Date (default: today).
	-v          Verbose output.
	-h          Show this help.
" >&2
	exit 1
}

# Read a value from prudynt.json, stripping surrounding quotes
prudynt_get() {
	jct "$PRUDYNT_CONFIG" get "$1" 2>/dev/null | tr -d '"'
}

time_for_cron() {
	local t="$1"
	printf "%02d %02d" $((t % 60)) $((t / 60))
}

time_with_offset() {
	local h m raw
	raw=$(jct "$API_DATA_FILE" get "results.$1" 2>/dev/null | tr -d '"')
	h=$(printf '%s' "$raw" | awk -F[T:] '{print $2}' | sed 's/^0*//')
	m=$(printf '%s' "$raw" | awk -F[T:] '{print $3}' | sed 's/^0*//')
	[ -z "$h" ] && h=0
	[ -z "$m" ] && m=0
	echo $(( (1440 + h * 60 + m + $2) % 1440 ))
}

# Load defaults from prudynt.json
lat=$(prudynt_get "daynight.sun.latitude")
lng=$(prudynt_get "daynight.sun.longitude")
offset_sr=$(prudynt_get "daynight.sun.sunrise_offset")
offset_ss=$(prudynt_get "daynight.sun.sunset_offset")

# Defaults for offsets if unset
[ -z "$offset_sr" ] && offset_sr=0
[ -z "$offset_ss" ] && offset_ss=0

# Override with command line arguments
while getopts d:r:s:x:y:vh flag; do
	case "$flag" in
		d) date_arg=$OPTARG ;;
		r) offset_sr=$OPTARG ;;
		s) offset_ss=$OPTARG ;;
		x) lat=$OPTARG ;;
		y) lng=$OPTARG ;;
		v) verbose="true" ;;
		h | *) show_help ;;
	esac
done

[ -z "$date_arg" ] && date_arg="today"

if [ -z "$lat" ]; then
	echo_error "Latitude not configured"
	exit 1
fi

if [ -z "$lng" ]; then
	echo_error "Longitude not configured"
	exit 1
fi

echo_info "Fetching sunrise/sunset for lat=$lat lng=$lng date=$date_arg"

tz=$(tr ' ' '_' < /etc/timezone)

[ "$verbose" = "true" ] && verbosity="--verbose" || verbosity="--silent"
$CURL $verbosity --output "$API_DATA_FILE" \
	--url "$API_URL?formatted=0&date=$date_arg&lat=$lat&lng=$lng&tzid=$tz"

if [ ! -s "$API_DATA_FILE" ]; then
	echo_error "Failed to fetch sunrise/sunset data"
	exit 1
fi

[ "$verbose" = "true" ] && jct "$API_DATA_FILE" print

sr_time=$(time_with_offset "sunrise" "$offset_sr")
ss_time=$(time_with_offset "sunset" "$offset_ss")
rm -f "$API_DATA_FILE"

echo_info "Sunrise cron: $(time_for_cron "$sr_time") (offset ${offset_sr}m)"
echo_info "Sunset  cron: $(time_for_cron "$ss_time") (offset ${offset_ss}m)"

tmpfile=$(mktemp)
cp "$CRONTABS" "$tmpfile"
sed -i "/dusk2dawn/d" "$tmpfile"
sed -i "/$SR_MARK/,+1d" "$tmpfile"
sed -i "/$SS_MARK/,+1d" "$tmpfile"
{
	echo "# run dusk2dawn nightly at 0:00 to refresh tomorrow's times"
	echo "0 0 * * * dusk2dawn"
	echo "$SR_MARK"
	echo "$(time_for_cron "$sr_time") * * * daynight day"
	echo "$SS_MARK"
	echo "$(time_for_cron "$ss_time") * * * daynight night"
} >> "$tmpfile"
cp "$tmpfile" "$CRONTABS"
rm -f "$tmpfile"

[ "$verbose" = "true" ] && crontab -l

exit 0
