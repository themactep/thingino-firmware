config BR2_PACKAGE_THINGINO_RAPTOR
	bool "Raptor Streaming System"
	depends on !BR2_SOC_FAMILY = "a1"
	depends on BR2_PACKAGE_THINGINO_STREAMER_RAPTOR
	select BR2_PACKAGE_INGENIC_LIB
	select BR2_PACKAGE_INGENIC_MUSL if BR2_TOOLCHAIN_USES_MUSL
	select BR2_PACKAGE_INGENIC_UCLIBC if BR2_TOOLCHAIN_USES_UCLIBC
	select BR2_PACKAGE_LIBSCHRIFT
	select BR2_PACKAGE_THINGINO_FONTS
	select BR2_PACKAGE_THINGINO_LOGO
	select BR2_PACKAGE_COMPY
	select BR2_PACKAGE_THINGINO_RAPTOR_HAL
	select BR2_PACKAGE_THINGINO_RAPTOR_IPC
	select BR2_PACKAGE_THINGINO_RAPTOR_COMMON
	help
	  Raptor Streaming System (RSS) -- modular microservice streamer
	  for Ingenic SoCs. Replaces prudynt-t with independent daemons:
	  RVD (video), RAD (audio), RSD (RTSP), ROD (OSD), RHD (HTTP),
	  RIC (IR-cut), RMR (recording), plus raptorctl management CLI.

if BR2_PACKAGE_THINGINO_RAPTOR

menu "Daemon selection"

config BR2_PACKAGE_THINGINO_RAPTOR_FULL
	bool "Full (all daemons)"
	default y
	help
	  Build and install all raptor daemons. Disable to select
	  individual daemons below. RVD (video) and tools (raptorctl,
	  ringdump, rac) are always included.

config BR2_PACKAGE_THINGINO_RAPTOR_RSD
	bool "RSD (RTSP server)"
	default y if BR2_PACKAGE_THINGINO_RAPTOR_FULL

config BR2_PACKAGE_THINGINO_RAPTOR_RAD
	bool "RAD (audio capture/speaker)"
	default y if BR2_PACKAGE_THINGINO_RAPTOR_FULL

config BR2_PACKAGE_THINGINO_RAPTOR_RHD
	bool "RHD (HTTP snapshots/MJPEG)"
	default y if BR2_PACKAGE_THINGINO_RAPTOR_FULL

config BR2_PACKAGE_THINGINO_RAPTOR_ROD
	bool "ROD (OSD renderer)"
	default y if BR2_PACKAGE_THINGINO_RAPTOR_FULL

config BR2_PACKAGE_THINGINO_RAPTOR_RIC
	bool "RIC (IR-cut controller)"
	default y if BR2_PACKAGE_THINGINO_RAPTOR_FULL

config BR2_PACKAGE_THINGINO_RAPTOR_RMR
	bool "RMR (fMP4 recording)"
	default y if BR2_PACKAGE_THINGINO_RAPTOR_FULL

config BR2_PACKAGE_THINGINO_RAPTOR_RMD
	bool "RMD (motion detection)"
	default y if BR2_PACKAGE_THINGINO_RAPTOR_FULL

config BR2_PACKAGE_THINGINO_RAPTOR_WEBRTC
	bool "RWD (WebRTC/WHIP server)"
	default y if BR2_PACKAGE_THINGINO_RAPTOR_FULL
	depends on BR2_PACKAGE_THINGINO_RAPTOR_TLS
	select BR2_PACKAGE_MBEDTLS_DTLS_SRTP
	help
	  WebRTC streaming daemon with WHIP signaling, two-way audio
	  backchannel, and HTTPS. Requires TLS support (mbedTLS).

config BR2_PACKAGE_THINGINO_RAPTOR_RWC
	bool "RWC (USB webcam)"
	depends on BR2_PACKAGE_THINGINO_KOPT_GADGET_WEBCAM
	help
	  USB webcam daemon. Reads JPEG/H.264 frames from ring buffers
	  and feeds them to the UVC gadget. Requires USB Gadget Webcam
	  kernel option.

config BR2_PACKAGE_THINGINO_RAPTOR_WEBTORRENT
	bool "WebTorrent sharing (external WebRTC)"
	default y if BR2_PACKAGE_THINGINO_RAPTOR_WEBRTC
	depends on BR2_PACKAGE_THINGINO_RAPTOR_WEBRTC
	help
	  Peer-to-peer external sharing via WebTorrent trackers.
	  View camera without port forwarding.

config BR2_PACKAGE_THINGINO_RAPTOR_RAC
	bool "rac (audio record/playback tool)"
	default y if BR2_PACKAGE_THINGINO_RAPTOR_RAD
	depends on BR2_PACKAGE_THINGINO_RAPTOR_RAD

endmenu

menu "Codec and feature options"

config BR2_PACKAGE_THINGINO_RAPTOR_AAC
	bool "AAC audio support"
	default y
	select BR2_PACKAGE_FAAC
	select BR2_PACKAGE_LIBHELIX_AAC
	help
	  AAC audio codec for encoding and decoding.

config BR2_PACKAGE_THINGINO_RAPTOR_OPUS
	bool "Opus audio support"
	default y
	select BR2_PACKAGE_OPUS
	help
	  Opus audio codec support.

config BR2_PACKAGE_THINGINO_RAPTOR_MP3
	bool "MP3 audio decoding"
	default y if FLASH_SIZE_MB > 8
	select BR2_PACKAGE_LIBHELIX_MP3
	help
	  MP3 decoding for audio client (rac).

config BR2_PACKAGE_THINGINO_RAPTOR_TLS
	bool "TLS support (RTSPS, HTTPS)"
	default y
	select BR2_PACKAGE_MBEDTLS
	help
	  Enable mbedTLS for RTSPS, RWD HTTPS signaling, and
	  optional RHD HTTPS.

config BR2_PACKAGE_THINGINO_RAPTOR_IVS_DETECT
	bool "IVS detection (person/object/YOLO)"
	default n
	select BR2_PACKAGE_INGENIC_LIB_JZDL
	select BR2_PACKAGE_MAGIK_MODELS
	select BR2_PACKAGE_MAGIK_MODELS_YOLOV5
	help
	  JZDL YOLOv5 inference and motion bounding box tracking.
	  Installs JZDL (609KB) and YOLOv5 model (870KB).
	  Enable personDet separately in ingenic-lib for the
	  built-in person detection algorithm (+1.5MB).

config BR2_PACKAGE_THINGINO_RAPTOR_AUDIO_EFFECTS
	bool "Audio effects (NS/HPF/AGC)"
	default y
	select BR2_PACKAGE_INGENIC_LIB_AUDIOPROCESS
	help
	  Noise suppression, high-pass filter, and automatic
	  gain control. Requires libaudioProcess.so from Ingenic SDK.

config BR2_PACKAGE_THINGINO_RAPTOR_DEBUG
	bool "Debug build"
	help
	  Build with -O0 -g instead of -Os. Debug binaries are
	  significantly larger.

endmenu

source "$BR2_EXTERNAL_THINGINO_PATH/package/thingino-raptor/Config.in.conf"

endif # BR2_PACKAGE_THINGINO_RAPTOR
