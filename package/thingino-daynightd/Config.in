config BR2_PACKAGE_THINGINO_DAYNIGHTD
	bool "thingino-daynightd"
	help
	  Day/Night photosensing daemon — single source of truth
	  for automatic day/night mode switching on Thingino.
	  
	  Reads ISP sensor data from /proc/jz/isp/, runs a
	  hysteresis-based algorithm, applies mode changes via
	  /sbin/daynight, and exports live telemetry to
	  /run/thingino/ for all consumers.

if BR2_PACKAGE_THINGINO_DAYNIGHTD

config BR2_PACKAGE_THINGINO_DAYNIGHTD_AUTOSTART
	bool "Auto-start at boot"
	default y
	help
	  Automatically start daynightd at boot (priority S10,
	  before streamer and web UI).

endif
