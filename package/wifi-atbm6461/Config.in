config BR2_PACKAGE_WIFI_ATBM6461
	bool "AltoBeam ATBM6461 (binary)"
	select BR2_LINUX_KERNEL
	select BR2_PACKAGE_ATBM6461_TOOLS
	select BR2_PACKAGE_THINGINO_KOPT_MMC
	help
	  Binary WiFi+MCU driver for AltoBeam ATBM6461 SDIO.
	  Used by the ZRT/AJCloud T23ZN OS02G10 ATBM6461 camera family,
	  including Wansview A1 and Cinnado B6.

	  Source unavailable; .ko extracted from stock recovery initramfs.
	  Vermagic is patched at build time to match the kernel version.
	  Kernel localversion must be short enough to fit (≤9 chars including
	  the leading dash), e.g. CONFIG_LOCALVERSION="-Archon".

	  Also builds z7682_disable_wdt from recovered source, selects
	  atbm6461-tools for MCU WiFi/battery commands, and ships librtos.so
	  for MCU watchdog communication via /dev/atbm_ioctl.
