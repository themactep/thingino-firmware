thingino_agent_prudynt_parse_osd_path() {
	path=$1
	stream_id=${path#streams/}
	stream_id=${stream_id%%/*}
	relative=${path#streams/$stream_id/osd/}
	[ -n "$stream_id" ] && [ "$relative" != "$path" ] || return 1
	spec=$(thingino_agent_prudynt_osd_spec "$relative") || return 1
	printf '%s|%s|%s|%s\n' "$stream_id" "$relative" "$spec"
}

thingino_agent_prudynt_print_osd_setting() {
	path=$1
	parsed=$(thingino_agent_prudynt_parse_osd_path "$path") || {
		echo "unsupported setting path: $path" >&2
		return 1
	}
	OLDIFS=$IFS
	IFS='|'
	set -- $parsed
	IFS=$OLDIFS
	stream_id=$1
	config_key=$3
	response_key=$4
	value_type=$5
	if [ "$value_type" = text ]; then
		printf '{"%s":%s}\n' "$response_key" "$(thingino_agent_json_string_or_null "$(thingino_agent_prudynt_stream_osd_text_field "$stream_id" "$config_key")")"
	else
		thingino_agent_print_setting_leaf "$response_key" "$(thingino_agent_prudynt_stream_osd_field "$stream_id" "$config_key")"
	fi
}

thingino_agent_prudynt_osd_json_value() {
	value_type=$1
	raw_value=$2
	case "$value_type" in
		bool)
			thingino_agent_prudynt_validate_bool "$raw_value" || return 1
			printf '%s' "$raw_value"
			;;
		int)
			thingino_agent_prudynt_validate_int "$raw_value" || return 1
			printf '%s' "$raw_value"
			;;
		text)
			printf '%s' "$(thingino_agent_json_string "$(thingino_agent_prudynt_unquote_string "$raw_value")")"
			;;
		*)
			echo "unsupported OSD value type: $value_type" >&2
			return 1
			;;
	esac
}

thingino_agent_prudynt_osd_payload() {
	stream_id=$1
	config_key=$2
	json_value=$3
	case "$config_key" in
		*.*)
			group=${config_key%%.*}
			leaf=${config_key#*.}
			printf '{"stream%s":{"osd":{"%s":{"%s":%s}}}}' "$stream_id" "$group" "$leaf" "$json_value"
			;;
		*)
			printf '{"stream%s":{"osd":{"%s":%s}}}' "$stream_id" "$config_key" "$json_value"
			;;
	esac
}

thingino_agent_prudynt_set_osd_setting() {
	path=$1
	body_file=$2
	parsed=$(thingino_agent_prudynt_parse_osd_path "$path") || {
		echo "unsupported setting path: $path" >&2
		return 1
	}
	OLDIFS=$IFS
	IFS='|'
	set -- $parsed
	IFS=$OLDIFS
	stream_id=$1
	config_key=$3
	response_key=$4
	value_type=$5
	raw_value=$(thingino_agent_prudynt_setting_value "$body_file" "$response_key") || return 1
	json_value=$(thingino_agent_prudynt_osd_json_value "$value_type" "$raw_value") || return 1
	payload=$(thingino_agent_prudynt_osd_payload "$stream_id" "$config_key" "$json_value")
	thingino_agent_prudynt_apply_payload "$payload" || return 1
	thingino_agent_prudynt_persist_value "stream${stream_id}.osd.${config_key}" "$json_value"
	thingino_agent_print_setting_update "$path" "$response_key" "$json_value"
}

