thingino_agent_prudynt_apply_payload() {
	payload=$1
	if ! command -v prudyntctl >/dev/null 2>&1; then
		echo "prudyntctl is not available" >&2
		return 1
	fi
	printf '%s\n' "$payload" | prudyntctl json - >/dev/null 2>&1 || {
		echo "failed to apply prudynt runtime configuration" >&2
		return 1
	}
}

thingino_agent_prudynt_persist_value() {
	path=$1
	value=$2
	if command -v jct >/dev/null 2>&1 && [ -f "$THINGINO_AGENT_PRUDYNT_CONFIG" ] && [ -n "$value" ]; then
		jct "$THINGINO_AGENT_PRUDYNT_CONFIG" set "$path" "$value" >/dev/null 2>&1 || true
	fi
}

thingino_agent_prudynt_setting_value() {
	body_file=$1
	field=$2
	value=$(thingino_agent_json_config_value "$body_file" "$field")
	[ -n "$value" ] || {
		echo "missing field '$field'" >&2
		return 1
	}
	printf '%s' "$value"
}

thingino_agent_prudynt_validate_bool() {
	case "$1" in
		true|false) return 0 ;;
		*) echo "boolean value required" >&2; return 1 ;;
	esac
}

thingino_agent_prudynt_validate_int() {
	value=$1
	case "$value" in
		''|*[!0-9-]*) echo "integer value required" >&2; return 1 ;;
		*) return 0 ;;
	esac
}

thingino_agent_prudynt_unquote_string() {
	printf '%s' "$1" | tr -d '"'
}

thingino_agent_prudynt_validate_non_empty_string() {
	value=$(thingino_agent_prudynt_unquote_string "$1")
	[ -n "$value" ] || {
		echo "non-empty string required" >&2
		return 1
	}
	printf '%s' "$value"
}

thingino_agent_prudynt_validate_stream_format() {
	value=$(thingino_agent_prudynt_unquote_string "$1" | tr 'a-z' 'A-Z')
	case "$value" in
		H264|H265)
			printf '%s' "$value"
			return 0
			;;
		*)
			echo "stream format must be H264 or H265" >&2
			return 1
			;;
	esac
}

thingino_agent_prudynt_validate_stream_mode() {
	value=$(thingino_agent_prudynt_unquote_string "$1" | tr 'a-z' 'A-Z')
	case "$value" in
		CBR|VBR|SMART|FIXQP|CAPPED_VBR|CAPPED_QUALITY)
			printf '%s' "$value"
			return 0
			;;
		*)
			echo "stream mode must be CBR, VBR, SMART, FIXQP, CAPPED_VBR, or CAPPED_QUALITY" >&2
			return 1
			;;
	esac
}

