#!/bin/sh

THINGINO_AGENT_PRUDYNT_CONFIG="${THINGINO_AGENT_PRUDYNT_CONFIG:-/etc/prudynt.json}"
THINGINO_AGENT_SEND2_CONFIG="${THINGINO_AGENT_SEND2_CONFIG:-/etc/send2.json}"

thingino_agent_adapter_prudynt_detect() {
	[ -f "$THINGINO_AGENT_PRUDYNT_CONFIG" ] \
		|| command -v prudyntctl >/dev/null 2>&1 \
		|| [ -f /etc/init.d/S31prudynt ]
}

thingino_agent_adapter_prudynt_name() {
	printf 'prudynt'
}

thingino_agent_prudynt_raw() {
	thingino_agent_json_config_value "$THINGINO_AGENT_PRUDYNT_CONFIG" "$1"
}

thingino_agent_prudynt_text() {
	thingino_agent_prudynt_raw "$1" | tr -d '"'
}

thingino_agent_prudynt_streamer_running() {
	pidof prudynt >/dev/null 2>&1 && printf 'true' || printf 'false'
}

thingino_agent_prudynt_network_ip() {
	thingino_agent_default_ip
}

thingino_agent_prudynt_network_online() {
	ip_addr=$(thingino_agent_prudynt_network_ip)
	[ -n "$ip_addr" ] && printf 'true' || printf 'false'
}

thingino_agent_prudynt_health_status() {
	if [ "$(thingino_agent_prudynt_streamer_running)" = true ] && [ "$(thingino_agent_prudynt_network_online)" = true ]; then
		printf 'ok'
	else
		printf 'degraded'
	fi
}

thingino_agent_prudynt_service_script() {
	[ -f /etc/init.d/S31prudynt ] && printf '/etc/init.d/S31prudynt'
}

thingino_agent_prudynt_streaming_controllable() {
	[ -n "$(thingino_agent_prudynt_service_script)" ] && printf 'true' || printf 'false'
}

thingino_agent_prudynt_has_snapshot() {
	command -v prudyntctl >/dev/null 2>&1 && printf 'true' || printf 'false'
}

thingino_agent_prudynt_has_clip() {
	[ -e /run/prudynt/mp4ctl ] && printf 'true' || printf 'false'
}

thingino_agent_prudynt_has_privacy() {
	if command -v privacy >/dev/null 2>&1 || [ -e /run/prudynt/video_ctrl ]; then
		printf 'true'
	else
		printf 'false'
	fi
}

thingino_agent_prudynt_has_daynight() {
	if command -v prudyntctl >/dev/null 2>&1 || [ -f /run/prudynt/daynight_mode ] || [ -f "$THINGINO_AGENT_PRUDYNT_CONFIG" ]; then
		printf 'true'
	else
		printf 'false'
	fi
}

thingino_agent_prudynt_has_ptz() {
	command -v motors >/dev/null 2>&1 && printf 'true' || printf 'false'
}

thingino_agent_prudynt_stream_count() {
	printf '2'
}

thingino_agent_prudynt_send2_service_supported() {
	case "$1" in
		email|ftp|gphotos|mqtt|ntfy|storage|telegram|webhook) return 0 ;;
		*) echo "unsupported send2 service: $1" >&2; return 1 ;;
	esac
}

thingino_agent_prudynt_send2_service_has_send_video() {
	case "$1" in
		email|ftp|gphotos|mqtt|ntfy|storage|telegram|webhook) return 0 ;;
		*) return 1 ;;
	esac
}

thingino_agent_prudynt_send2_motion_key() {
	printf 'motion.send2%s' "$1"
}

thingino_agent_prudynt_send2_motion_enabled() {
	service=$1
	thingino_agent_json_value_or "$(thingino_agent_prudynt_raw "$(thingino_agent_prudynt_send2_motion_key "$service")")" false
}

thingino_agent_prudynt_send2_raw() {
	service=$1
	field=$2
	thingino_agent_json_config_value "$THINGINO_AGENT_SEND2_CONFIG" "$service.$field"
}

thingino_agent_prudynt_recorder_raw() {
	thingino_agent_prudynt_raw "recorder.$1"
}

thingino_agent_prudynt_recorder_text() {
	thingino_agent_prudynt_text "recorder.$1"
}

thingino_agent_prudynt_storage_spec() {
	case "$1" in
		autostart) printf 'autostart|autostart|bool\n' ;;
		channel) printf 'channel|channel|int\n' ;;
		device-path) printf 'device_path|device_path|text\n' ;;
		duration) printf 'duration|duration|int\n' ;;
		filename) printf 'filename|filename|text\n' ;;
		mount) printf 'mount|mount|text\n' ;;
		*) return 1 ;;
	esac
}

thingino_agent_prudynt_parse_storage_path() {
	relative=${1#storage/}
	[ "$relative" != "$1" ] || return 1
	spec=$(thingino_agent_prudynt_storage_spec "$relative") || return 1
	printf '%s|%s\n' "$relative" "$spec"
}

thingino_agent_prudynt_storage_json_value() {
	value_type=$1
	raw_value=$2
	case "$value_type" in
		bool)
			thingino_agent_prudynt_validate_bool "$raw_value" || return 1
			printf '%s' "$raw_value"
			;;
		int)
			thingino_agent_prudynt_validate_int "$raw_value" || return 1
			printf '%s' "$raw_value"
			;;
		text)
			printf '%s' "$(thingino_agent_json_string "$(thingino_agent_prudynt_unquote_string "$raw_value")")"
			;;
		*)
			echo "unsupported storage value type: $value_type" >&2
			return 1
			;;
	esac
}

thingino_agent_prudynt_print_storage_setting() {
	parsed=$(thingino_agent_prudynt_parse_storage_path "$1") || {
		echo "unsupported setting path: $1" >&2
		return 1
	}
	OLDIFS=$IFS
	IFS='|'
	set -- $parsed
	IFS=$OLDIFS
	config_key=$2
	response_key=$3
	value_type=$4
	if [ "$value_type" = text ]; then
		printf '{"%s":%s}\n' "$response_key" "$(thingino_agent_json_string_or_null "$(thingino_agent_prudynt_recorder_text "$config_key")")"
	else
		thingino_agent_print_setting_leaf "$response_key" "$(thingino_agent_prudynt_recorder_raw "$config_key")"
	fi
}

thingino_agent_prudynt_set_storage_setting() {
	storage_path=$1
	body_file=$2
	parsed=$(thingino_agent_prudynt_parse_storage_path "$storage_path") || {
		echo "unsupported setting path: $storage_path" >&2
		return 1
	}
	OLDIFS=$IFS
	IFS='|'
	set -- $parsed
	IFS=$OLDIFS
	config_key=$2
	response_key=$3
	value_type=$4
	if [ "$value_type" = text ]; then
		raw_value=$(thingino_agent_json_config_value "$body_file" "$response_key")
		if [ -z "$raw_value" ]; then
			if grep -q '"'"$response_key"'"[[:space:]]*:[[:space:]]*""' "$body_file"; then
				raw_value='""'
			else
				echo "missing field '$response_key'" >&2
				return 1
			fi
		fi
	else
		raw_value=$(thingino_agent_prudynt_setting_value "$body_file" "$response_key") || return 1
	fi
	json_value=$(thingino_agent_prudynt_storage_json_value "$value_type" "$raw_value") || return 1
	thingino_agent_prudynt_apply_payload "{\"recorder\":{\"$config_key\":$json_value}}" || return 1
	thingino_agent_prudynt_persist_value "recorder.$config_key" "$json_value"
	thingino_agent_print_setting_update "$storage_path" "$response_key" "$json_value"
}

thingino_agent_prudynt_storage_mount_type() {
	mount_path=$(thingino_agent_prudynt_recorder_text mount)
	[ -n "$mount_path" ] || return 0
	mount | awk -v mount_path="$mount_path" '$3 == mount_path { print $5; exit }' | tr -d '\n'
}

thingino_agent_prudynt_storage_is_mounted() {
	[ -n "$(thingino_agent_prudynt_storage_mount_type)" ] && printf 'true' || printf 'false'
}

thingino_agent_prudynt_storage_resolved_root() {
	mount_path=$(thingino_agent_prudynt_recorder_text mount)
	[ -n "$mount_path" ] || return 0
	device_path=$(thingino_agent_prudynt_recorder_text device_path)
	hostname=$(thingino_agent_hostname)
	device_path=$(printf '%s' "$device_path" | sed "s/%hostname/$hostname/g")
	case "$device_path" in
		'') printf '%s' "$mount_path" ;;
		*) printf '%s/%s' "$mount_path" "$device_path" ;;
	esac
}

thingino_agent_prudynt_print_runtime_storage() {
	mount_path=$(thingino_agent_prudynt_recorder_text mount)
	mount_type=$(thingino_agent_prudynt_storage_mount_type)
	mounted=$(thingino_agent_json_bool "$(thingino_agent_prudynt_storage_is_mounted)")
	resolved_root=$(thingino_agent_prudynt_storage_resolved_root)
	writable=false
	total_kib=null
	used_kib=null
	available_kib=null
	if [ -n "$mount_type" ]; then
		[ -w "$mount_path" ] && writable=true
		df_line=$(df -k "$mount_path" 2>/dev/null | awk 'NR == 2 { print $2 "|" $3 "|" $4; exit }')
		if [ -n "$df_line" ]; then
			OLDIFS=$IFS
			IFS='|'
			set -- $df_line
			IFS=$OLDIFS
			total_kib=$1
			used_kib=$2
			available_kib=$3
		fi
	fi
	printf '{'
	printf '"configured_mount":%s,' "$(thingino_agent_json_string_or_null "$mount_path")"
	printf '"mounted":%s,' "$mounted"
	printf '"filesystem":%s,' "$(thingino_agent_json_string_or_null "$mount_type")"
	printf '"record_root":%s,' "$(thingino_agent_json_string_or_null "$resolved_root")"
	printf '"writable":%s,' "$(thingino_agent_json_bool "$writable")"
	printf '"total_kib":%s,' "$total_kib"
	printf '"used_kib":%s,' "$used_kib"
	printf '"available_kib":%s' "$available_kib"
	printf '}'
}

thingino_agent_prudynt_recording_active_file() {
	for active_file in /run/prudynt/mp4ctl-ch*.active; do
		[ -f "$active_file" ] || continue
		printf '%s' "$active_file"
		return 0
	done
	return 1
}

thingino_agent_prudynt_recording_active_value() {
	active_file=$1
	key=$2
	[ -f "$active_file" ] || return 0
	active_line=$(sed -n '1p' "$active_file" 2>/dev/null | tr '\r\n' ' ')
	[ -n "$active_line" ] || return 0
	printf '%s\n' "$active_line" | tr ' ' '\n' | awk -F= -v key="$key" '$1 == key { print substr($0, index($0, "=") + 1); exit }' | tr -d '\n'
}

thingino_agent_prudynt_recording_active_channel() {
	active_file=$1
	active_channel=$(thingino_agent_prudynt_recording_active_value "$active_file" ch)
	if [ -n "$active_channel" ]; then
		printf '%s' "$active_channel"
		return 0
	fi
	printf '%s' "$active_file" | sed -n 's|.*/mp4ctl-ch\([0-9][0-9]*\)\.active|\1|p' | tr -d '\n'
}

thingino_agent_prudynt_print_runtime_recording() {
	supported=$(thingino_agent_json_bool "$(thingino_agent_prudynt_has_clip)")
	configured_autostart=$(thingino_agent_json_value_or "$(thingino_agent_prudynt_recorder_raw autostart)" false)
	configured_channel=$(thingino_agent_json_value_or "$(thingino_agent_prudynt_recorder_raw channel)" null)
	configured_duration=$(thingino_agent_json_value_or "$(thingino_agent_prudynt_recorder_raw duration)" null)
	configured_mount=$(thingino_agent_prudynt_recorder_text mount)
	record_root=$(thingino_agent_prudynt_storage_resolved_root)
	storage_writable=$(thingino_agent_json_bool "$( [ "$(thingino_agent_prudynt_storage_is_mounted)" = true ] && [ -n "$configured_mount" ] && [ -w "$configured_mount" ] && printf true || printf false )")
	active=false
	current_channel=null
	current_duration=null
	current_path=
	current_mount=
	current_directory=
	current_name_template=
	loop=null
	active_file=$(thingino_agent_prudynt_recording_active_file)
	if [ -n "$active_file" ]; then
		active=true
		active_channel=$(thingino_agent_prudynt_recording_active_channel "$active_file")
		active_duration=$(thingino_agent_prudynt_recording_active_value "$active_file" dur)
		active_path=$(thingino_agent_prudynt_recording_active_value "$active_file" path)
		active_mount=$(thingino_agent_prudynt_recording_active_value "$active_file" mount)
		active_directory=$(thingino_agent_prudynt_recording_active_value "$active_file" dir)
		active_name=$(thingino_agent_prudynt_recording_active_value "$active_file" name)
		active_loop=$(thingino_agent_prudynt_recording_active_value "$active_file" loop)
		[ -n "$active_channel" ] && current_channel=$active_channel
		[ -n "$active_duration" ] && current_duration=$active_duration
		current_path=$active_path
		current_mount=$active_mount
		current_directory=$active_directory
		current_name_template=$active_name
		case "$active_loop" in
			1|true) loop=true ;;
			0|false) loop=false ;;
			*) loop=null ;;
		esac
	fi
	printf '{'
	printf '"supported":%s,' "$supported"
	printf '"active":%s,' "$(thingino_agent_json_bool "$active")"
	printf '"configured_autostart":%s,' "$configured_autostart"
	printf '"configured_channel":%s,' "$configured_channel"
	printf '"configured_duration_seconds":%s,' "$configured_duration"
	printf '"configured_mount":%s,' "$(thingino_agent_json_string_or_null "$configured_mount")"
	printf '"record_root":%s,' "$(thingino_agent_json_string_or_null "$record_root")"
	printf '"writable":%s,' "$storage_writable"
	printf '"current_channel":%s,' "$current_channel"
	printf '"current_duration_seconds":%s,' "$current_duration"
	printf '"current_path":%s,' "$(thingino_agent_json_string_or_null "$current_path")"
	printf '"current_mount":%s,' "$(thingino_agent_json_string_or_null "$current_mount")"
	printf '"current_directory":%s,' "$(thingino_agent_json_string_or_null "$current_directory")"
	printf '"current_name_template":%s,' "$(thingino_agent_json_string_or_null "$current_name_template")"
	printf '"loop":%s' "$loop"
	printf '}'
}

thingino_agent_prudynt_print_send2_capabilities() {
	printf '{'
	sep=''
	for service in email ftp gphotos mqtt ntfy storage telegram webhook; do
		printf '%s"%s":{"enabled":true,"send_photo":true,"send_video":%s}' \
			"$sep" "$service" \
			"$(thingino_agent_json_bool "$(thingino_agent_prudynt_send2_service_has_send_video "$service" && printf true || printf false)")"
		sep=,
	done
	printf '}'
}

thingino_agent_prudynt_print_service_capabilities() {
	streaming_service=false
	[ -n "$(thingino_agent_prudynt_service_script)" ] && streaming_service=true
	printf '{"streaming":{"start":%s,"stop":%s,"restart":%s}}' \
		"$(thingino_agent_json_bool "$streaming_service")" \
		"$(thingino_agent_json_bool "$streaming_service")" \
		"$(thingino_agent_json_bool "$streaming_service")"
}

thingino_agent_prudynt_print_firmware_capabilities() {
	printf '{"upgrade":%s}' "$(thingino_agent_json_bool "$(command -v sysupgrade >/dev/null 2>&1 && printf true || printf false)")"
}

thingino_agent_prudynt_firmware_upgrade_supported() {
	command -v sysupgrade >/dev/null 2>&1 && printf 'true' || printf 'false'
}

thingino_agent_prudynt_firmware_pending_full() {
	[ -f /tmp/upgrade.me ] && printf 'true' || printf 'false'
}

thingino_agent_prudynt_firmware_pending_partial() {
	[ -f /tmp/update.me ] && printf 'true' || printf 'false'
}

thingino_agent_prudynt_firmware_boot_marked_complete() {
	if command -v fw_printenv >/dev/null 2>&1; then
		value=$(fw_printenv -n sysupgrade_complete 2>/dev/null | tr -d '\n')
		case "$value" in
			1|true|TRUE|yes|on) printf 'true' ;;
			0|false|FALSE|no|off) printf 'false' ;;
			'') printf 'null' ;;
			*) printf 'null' ;;
		esac
	else
		printf 'null'
	fi
}

thingino_agent_prudynt_firmware_pending_action() {
	if [ "$(thingino_agent_prudynt_firmware_pending_full)" = true ]; then
		printf 'full'
	elif [ "$(thingino_agent_prudynt_firmware_pending_partial)" = true ]; then
		printf 'partial'
	else
		printf 'none'
	fi
}

thingino_agent_prudynt_print_runtime_firmware() {
	printf '{'
	printf '"upgrade_supported":%s,' "$(thingino_agent_json_bool "$(thingino_agent_prudynt_firmware_upgrade_supported)")"
	printf '"pending_full":%s,' "$(thingino_agent_json_bool "$(thingino_agent_prudynt_firmware_pending_full)")"
	printf '"pending_partial":%s,' "$(thingino_agent_json_bool "$(thingino_agent_prudynt_firmware_pending_partial)")"
	printf '"pending_action":%s,' "$(thingino_agent_json_string "$(thingino_agent_prudynt_firmware_pending_action)")"
	printf '"boot_marked_complete":%s,' "$(thingino_agent_prudynt_firmware_boot_marked_complete)"
	printf '"current_version":%s' "$(thingino_agent_json_string_or_null "$(thingino_agent_firmware_version)")"
	printf '}'
}

thingino_agent_prudynt_motion_enabled() {
	thingino_agent_json_value_or "$(thingino_agent_prudynt_raw motion.enabled)" false
}

thingino_agent_prudynt_motion_active() {
	if [ -f /run/prudynt/motion.active ] || [ -f /run/prudynt/motion_detected.active ]; then
		printf 'true'
	else
		printf 'false'
	fi
}

thingino_agent_prudynt_daynight_enabled() {
	thingino_agent_json_value_or "$(thingino_agent_prudynt_raw daynight.enabled)" false
}

thingino_agent_prudynt_daynight_force_mode() {
	thingino_agent_json_value_or "$(thingino_agent_prudynt_raw daynight.force_mode)" null
}

thingino_agent_prudynt_daynight_running_mode() {
	if [ -f /run/prudynt/daynight_mode ]; then
		mode=$(awk 'NR == 1 { print $1 }' /run/prudynt/daynight_mode 2>/dev/null | tr -d '\n')
		[ -n "$mode" ] && {
			printf '%s' "$mode"
			return 0
		}
	fi
	if command -v prudyntctl >/dev/null 2>&1; then
		state=$(prudyntctl json - 2>/dev/null <<'EOF'
{"image":{"running_mode":null}}
EOF
)
		running=$(printf '%s' "$state" | grep -o '"running_mode":[^,}]*' | head -n 1 | cut -d: -f2 | tr -d ' "')
		case "$running" in
			0) printf 'day'; return 0 ;;
			1) printf 'night'; return 0 ;;
		esac
	fi
	printf 'unknown'
}

thingino_agent_prudynt_daynight_target_mode() {
	enabled=$(thingino_agent_prudynt_daynight_enabled)
	if [ "$enabled" = "true" ]; then
		printf 'auto'
	else
		mode=$(thingino_agent_prudynt_text daynight.force_mode)
		[ -n "$mode" ] || mode=$(thingino_agent_prudynt_daynight_running_mode)
		printf '%s' "$mode"
	fi
}

thingino_agent_prudynt_privacy_enabled() {
	[ -f /run/prudynt/privacy.active ] && printf 'true' || printf 'false'
}

thingino_agent_prudynt_stream_field() {
	stream_id=$1
	field=$2
	thingino_agent_prudynt_raw "stream${stream_id}.${field}"
}

thingino_agent_prudynt_stream_text_field() {
	stream_id=$1
	field=$2
	thingino_agent_prudynt_text "stream${stream_id}.${field}"
}

# Return the runtime value of a stream field (width/height/fps) by querying the
# running prudynt process via prudyntctl. Falls back to the static config value
# when prudyntctl is unavailable or returns 0.
thingino_agent_prudynt_runtime_stream_field() {
	stream_id=$1
	field=$2
	if command -v prudyntctl >/dev/null 2>&1; then
		_rt_tmp=$(mktemp)
		prudyntctl json "{\"stream${stream_id}\":{\"${field}\":null}}" >"$_rt_tmp" 2>/dev/null
		_rt_val=$(thingino_agent_json_config_value "$_rt_tmp" "stream${stream_id}.${field}")
		rm -f "$_rt_tmp"
		if [ -n "$_rt_val" ] && [ "$_rt_val" != "0" ] && [ "$_rt_val" != "null" ]; then
			printf '%s' "$_rt_val"
			return
		fi
	fi
	thingino_agent_prudynt_raw "stream${stream_id}.${field}"
}

thingino_agent_prudynt_rtsp_port() {
	rtsp_port=$(thingino_agent_prudynt_text rtsp.port)
	[ -n "$rtsp_port" ] || rtsp_port=554
	printf '%s' "$rtsp_port"
}

thingino_agent_prudynt_rtsp_listening() {
	rtsp_port=$(thingino_agent_prudynt_rtsp_port)
	if netstat -lnt 2>/dev/null | awk -v port=":$rtsp_port" 'index($4, port) { found=1; exit } END { exit(found ? 0 : 1) }'; then
		printf 'true'
	else
		printf 'false'
	fi
}

thingino_agent_prudynt_stream_recording_active() {
	stream_id=$1
	[ -f "/run/prudynt/mp4ctl-ch${stream_id}.active" ] && printf 'true' || printf 'false'
}

thingino_agent_prudynt_stream_healthy() {
	stream_id=$1
	enabled=$(thingino_agent_json_value_or "$(thingino_agent_prudynt_stream_field "$stream_id" enabled)" false)
	video_enabled=$(thingino_agent_json_value_or "$(thingino_agent_prudynt_stream_field "$stream_id" video_enabled)" false)
	rtsp_listener_up=$(thingino_agent_prudynt_rtsp_listening)
	if [ "$(thingino_agent_prudynt_streamer_running)" = true ] \
		&& [ "$enabled" = true ] \
		&& [ "$video_enabled" = true ] \
		&& [ "$rtsp_listener_up" = true ]; then
		printf 'true'
	else
		printf 'false'
	fi
}

thingino_agent_prudynt_event_append_path() {
	paths_json=$1
	path=$2
	path_json=$(thingino_agent_json_string "$path")
	if [ -n "$paths_json" ]; then
		printf '%s,%s' "$paths_json" "$path_json"
	else
		printf '%s' "$path_json"
	fi
}

thingino_agent_prudynt_stream_rtsp_url() {
	stream_id=$1
	endpoint=$(thingino_agent_prudynt_stream_text_field "$stream_id" rtsp_endpoint)
	[ -n "$endpoint" ] || return 0
	printf 'rtsp://127.0.0.1:%s/%s' "$(thingino_agent_prudynt_rtsp_port)" "$endpoint"
}

thingino_agent_prudynt_stream_osd_field() {
	stream_id=$1
	field=$2
	thingino_agent_prudynt_raw "stream${stream_id}.osd.${field}"
}

thingino_agent_prudynt_stream_osd_text_field() {
	stream_id=$1
	field=$2
	thingino_agent_prudynt_text "stream${stream_id}.osd.${field}"
}

thingino_agent_prudynt_osd_spec() {
	case "$1" in
		enabled) printf 'enabled|enabled|bool\n' ;;
		font-path) printf 'font_path|font_path|text\n' ;;
		font-size) printf 'font_size|font_size|int\n' ;;
		start-delay) printf 'start_delay|start_delay|int\n' ;;
		stroke-size) printf 'stroke_size|stroke_size|int\n' ;;
		brightness/enabled) printf 'brightness.enabled|enabled|bool\n' ;;
		brightness/fill-color) printf 'brightness.fill_color|fill_color|text\n' ;;
		brightness/format) printf 'brightness.format|format|text\n' ;;
		brightness/position) printf 'brightness.position|position|text\n' ;;
		brightness/rotation) printf 'brightness.rotation|rotation|int\n' ;;
		brightness/stroke-color) printf 'brightness.stroke_color|stroke_color|text\n' ;;
		time/enabled) printf 'time.enabled|enabled|bool\n' ;;
