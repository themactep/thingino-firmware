thingino_agent_adapter_prudynt_get_events() {
	retry_ms=3000
	printf 'retry: %s\n\n' "$retry_ms" || exit 0
	thingino_agent_sse_emit hello "$(thingino_agent_sse_payload hello '"backend":"prudynt","stream":"agent"')" || exit 0

	last_motion_active=$(thingino_agent_prudynt_motion_active)
	last_streamer_running=$(thingino_agent_prudynt_streamer_running)
	last_health_status=$(thingino_agent_prudynt_health_status)
	last_firmware_action=$(thingino_agent_prudynt_firmware_pending_action)
	last_stream0_recording=$(thingino_agent_prudynt_stream_recording_active 0)
	last_stream1_recording=$(thingino_agent_prudynt_stream_recording_active 1)
	last_stream0_healthy=$(thingino_agent_prudynt_stream_healthy 0)
	last_stream1_healthy=$(thingino_agent_prudynt_stream_healthy 1)
	last_active_file=$(thingino_agent_prudynt_recording_active_file)
	if [ -n "$last_active_file" ]; then
		last_recording_active=true
		last_recording_channel=$(thingino_agent_prudynt_recording_active_channel "$last_active_file")
		last_recording_duration=$(thingino_agent_prudynt_recording_active_value "$last_active_file" dur)
		last_recording_path=$(thingino_agent_prudynt_recording_active_value "$last_active_file" path)
	else
		last_recording_active=false
		last_recording_channel=
		last_recording_duration=
		last_recording_path=
	fi
	keepalive_counter=0

	while true; do
		sleep 2 || exit 0
		keepalive_counter=$((keepalive_counter + 1))
		changed_paths=

		current_motion_active=$(thingino_agent_prudynt_motion_active)
		if [ "$current_motion_active" != "$last_motion_active" ]; then
			changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" motion.active)
			if [ "$current_motion_active" = true ]; then
				thingino_agent_sse_emit motion.started "$(thingino_agent_sse_payload motion.started '"active":true')" || exit 0
			else
				thingino_agent_sse_emit motion.stopped "$(thingino_agent_sse_payload motion.stopped '"active":false')" || exit 0
			fi
		fi

		current_streamer_running=$(thingino_agent_prudynt_streamer_running)
		if [ "$current_streamer_running" != "$last_streamer_running" ]; then
			changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" system.streamer_running)
			changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" services.streaming.running)
			changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" services.streaming.healthy)
			if [ "$last_streamer_running" != true ] && [ "$current_streamer_running" = true ]; then
				thingino_agent_sse_emit streamer.restarted "$(thingino_agent_sse_payload streamer.restarted '"service":"streaming"')" || exit 0
			fi
		fi

		current_stream0_recording=$(thingino_agent_prudynt_stream_recording_active 0)
		if [ "$current_stream0_recording" != "$last_stream0_recording" ]; then
			changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" streams.0.recording_active)
		fi
		current_stream1_recording=$(thingino_agent_prudynt_stream_recording_active 1)
		if [ "$current_stream1_recording" != "$last_stream1_recording" ]; then
			changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" streams.1.recording_active)
		fi

		current_stream0_healthy=$(thingino_agent_prudynt_stream_healthy 0)
		if [ "$current_stream0_healthy" != "$last_stream0_healthy" ]; then
			changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" streams.0.healthy)
		fi
		current_stream1_healthy=$(thingino_agent_prudynt_stream_healthy 1)
		if [ "$current_stream1_healthy" != "$last_stream1_healthy" ]; then
			changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" streams.1.healthy)
		fi

		current_active_file=$(thingino_agent_prudynt_recording_active_file)
		if [ -n "$current_active_file" ]; then
			current_recording_active=true
			current_recording_channel=$(thingino_agent_prudynt_recording_active_channel "$current_active_file")
			current_recording_duration=$(thingino_agent_prudynt_recording_active_value "$current_active_file" dur)
			current_recording_path=$(thingino_agent_prudynt_recording_active_value "$current_active_file" path)
		else
			current_recording_active=false
			current_recording_channel=
			current_recording_duration=
			current_recording_path=
		fi

		if [ "$current_recording_active" != "$last_recording_active" ]; then
			changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" recording.active)
			changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" recording.current_channel)
			changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" recording.current_duration_seconds)
			changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" recording.current_path)
			if [ "$last_recording_active" = true ] && [ "$current_recording_active" != true ]; then
				record_fields=$(printf '"stream_id":%s,"path":%s,"duration_seconds":%s' \
					"$(thingino_agent_json_value_or "$last_recording_channel" null)" \
					"$(thingino_agent_json_string_or_null "$last_recording_path")" \
					"$(thingino_agent_json_value_or "$last_recording_duration" null)")
				thingino_agent_sse_emit record.completed "$(thingino_agent_sse_payload record.completed "$record_fields")" || exit 0
			fi
		else
			if [ "$current_recording_channel" != "$last_recording_channel" ]; then
				changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" recording.current_channel)
			fi
			if [ "$current_recording_duration" != "$last_recording_duration" ]; then
				changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" recording.current_duration_seconds)
			fi
			if [ "$current_recording_path" != "$last_recording_path" ]; then
				changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" recording.current_path)
			fi
		fi

		current_firmware_action=$(thingino_agent_prudynt_firmware_pending_action)
		if [ "$current_firmware_action" != "$last_firmware_action" ]; then
			changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" firmware.pending_action)
			changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" firmware.pending_full)
			changed_paths=$(thingino_agent_prudynt_event_append_path "$changed_paths" firmware.pending_partial)
			case "$current_firmware_action" in
				none) firmware_phase=idle ;;
				*) firmware_phase=pending ;;
			esac
			firmware_fields=$(printf '"action":%s,"phase":%s' \
				"$(thingino_agent_json_string "$current_firmware_action")" \
				"$(thingino_agent_json_string "$firmware_phase")")
			thingino_agent_sse_emit firmware.progress "$(thingino_agent_sse_payload firmware.progress "$firmware_fields")" || exit 0
		fi

		current_health_status=$(thingino_agent_prudynt_health_status)
		if [ "$current_health_status" != "$last_health_status" ] && [ "$current_health_status" != ok ]; then
			health_fields=$(printf '"status":%s,"network_online":%s,"streamer_running":%s' \
				"$(thingino_agent_json_string "$current_health_status")" \
				"$(thingino_agent_json_bool "$(thingino_agent_prudynt_network_online)")" \
				"$(thingino_agent_json_bool "$current_streamer_running")")
			thingino_agent_sse_emit health.warning "$(thingino_agent_sse_payload health.warning "$health_fields")" || exit 0
		fi

		if [ -n "$changed_paths" ]; then
			thingino_agent_sse_emit state.changed "$(thingino_agent_sse_payload state.changed "\"paths\":[${changed_paths}]")" || exit 0
			keepalive_counter=0
		elif [ "$keepalive_counter" -ge 3 ]; then
			thingino_agent_sse_emit keepalive "$(thingino_agent_sse_payload keepalive '')" || exit 0
			keepalive_counter=0
		fi

		last_motion_active=$current_motion_active
		last_streamer_running=$current_streamer_running
		last_health_status=$current_health_status
		last_firmware_action=$current_firmware_action
		last_stream0_recording=$current_stream0_recording
		last_stream1_recording=$current_stream1_recording
		last_stream0_healthy=$current_stream0_healthy
		last_stream1_healthy=$current_stream1_healthy
		last_recording_active=$current_recording_active
		last_recording_channel=$current_recording_channel
		last_recording_duration=$current_recording_duration
		last_recording_path=$current_recording_path
	done
}

