#!/bin/sh
. /usr/share/thingino-agent-api-common
require_method POST
require_token_if_configured
stream_id=$(query_param stream_id)
[ -n "$stream_id" ] || stream_id=0
tmpfile=$(mktemp /tmp/thingino-agent-snapshot.XXXXXX)
errfile=$(mktemp /tmp/thingino-agent-snapshot.err.XXXXXX)
if ! thingino-agentctl snapshot "$stream_id" >"$tmpfile" 2>"$errfile"; then
	err=$(cat "$errfile" 2>/dev/null)
	rm -f "$tmpfile" "$errfile"
	json_error 500 "${err:-thingino-agentctl failed}"
fi
rm -f "$errfile"
header_jpeg
cat "$tmpfile"
rm -f "$tmpfile"