usage() {
	cat <<'EOF'
Usage: thingino-agentctl <command> [args...]

Read commands:
  device                        Print canonical device identity JSON
  health                        Print coarse health JSON
  capabilities [group]          Print capability JSON
  runtime <resource|all>        Print runtime resource JSON
  state                         Compatibility alias for runtime all
  config                        Print full persisted config JSON
  schema                        Print machine-readable config schema JSON
  events                        Stream agent events in SSE format
  get-setting <path>            Print a narrow setting resource JSON

Write and action commands:
  set-setting <path> <json>     Apply a narrow setting resource update
  apply-config <json-file>      Compatibility bulk config patch
  snapshot [stream]             Write JPEG bytes to stdout
  record [seconds] [stream] [path]
  privacy <on|off> [channel]
  daynight <auto|day|night>
  service <name> <start|stop|restart>
  restart-streamer
  reboot

The agent owns the external API. Backend-specific glue is loaded through the
installed adapter modules.
EOF
	exit 1
}

command=$1
[ -n "$command" ] || usage
shift

load_adapter_modules
select_adapter || exit 1

case "$command" in
	device)
		print_device
		;;
	health)
		adapter_call get_health
		;;
	capabilities)
		group=${1:-all}
		adapter_call get_capabilities "$group"
		;;
	runtime)
		resource=${1:-all}
		adapter_call get_runtime "$resource"
		;;
	state)
		adapter_call get_runtime all
		;;
	config)
		adapter_call get_config
		;;
	schema)
		print_config_schema
		;;
	events)
		adapter_call get_events
		;;
	get-setting)
		path=$1
		[ -n "$path" ] || {
			echo "usage: thingino-agentctl get-setting <path>" >&2
			exit 1
		}
		adapter_call get_setting "$path"
		;;
	set-setting)
		path=$1
		body_file=$2
		[ -n "$path" ] || {
			echo "usage: thingino-agentctl set-setting <path> <json-file>" >&2
			exit 1
		}
		[ -n "$body_file" ] || {
			echo "usage: thingino-agentctl set-setting <path> <json-file>" >&2
			exit 1
		}
		adapter_call set_setting "$path" "$body_file"
		;;
	apply-config)
		body_file=$1
		[ -n "$body_file" ] || {
			echo "usage: thingino-agentctl apply-config <json-file>" >&2
			exit 1
		}
		adapter_call apply_config "$body_file"
		;;
	snapshot)
		adapter_call snapshot "$@"
		;;
	record)
		adapter_call record "$@"
		;;
	privacy)
		adapter_call privacy "$@"
		;;
	daynight)
		adapter_call daynight "$@"
		;;
	service)
		adapter_call service "$@"
		;;
	restart-streamer)
		adapter_call service streaming restart
		;;
	send2-test)
		adapter_call send2_test "$@"
		;;
	reboot)
		adapter_call reboot
		;;
	*)
		usage
		;;
esac