#!/bin/sh

. /usr/libexec/thingino-agent/lib.sh

THINGINO_AGENT_ADAPTER=

load_adapter_modules() {
	for module in /usr/libexec/thingino-agent/adapters/*.sh; do
		[ -r "$module" ] || continue
		. "$module"
	done
}

adapter_function() {
	action=$1
	printf 'thingino_agent_adapter_%s_%s' "$THINGINO_AGENT_ADAPTER" "$action"
}

adapter_call() {
	action=$1
	shift
	func=$(adapter_function "$action")
	if ! command -v "$func" >/dev/null 2>&1; then
		echo "adapter '$THINGINO_AGENT_ADAPTER' does not implement $action" >&2
		return 1
	fi
	"$func" "$@"
}

select_adapter() {
	configured=$(thingino_agent_text_config_value agent.backend)
	case "$configured" in
		""|auto)
			for candidate in prudynt null; do
				func="thingino_agent_adapter_${candidate}_detect"
				if command -v "$func" >/dev/null 2>&1 && "$func"; then
					THINGINO_AGENT_ADAPTER=$candidate
					return 0
				fi
			done
			;;
		prudynt|null)
			func="thingino_agent_adapter_${configured}_detect"
			if command -v "$func" >/dev/null 2>&1 && "$func"; then
				THINGINO_AGENT_ADAPTER=$configured
				return 0
			fi
			echo "configured backend '$configured' is not available" >&2
			return 1
			;;
		*)
			echo "unsupported configured backend '$configured'" >&2
			return 1
			;;
	esac

	echo "no camera-agent backend adapter is available" >&2
	return 1
}

print_device() {
	backend=$(adapter_call name)
	printf '{'
	printf '"id":%s,' "$(thingino_agent_json_string "$(thingino_agent_camera_id)")"
	printf '"name":%s,' "$(thingino_agent_json_string "$(thingino_agent_hostname)")"
	printf '"hostname":%s,' "$(thingino_agent_json_string "$(thingino_agent_hostname)")"
	printf '"manufacturer":"Thingino",'
	printf '"model":%s,' "$(thingino_agent_json_string "$(thingino_agent_camera_model)")"
	printf '"software":{'
	printf '"firmware_version":%s,' "$(thingino_agent_json_string "$(thingino_agent_firmware_version)")"
	printf '"api_version":"0-local",'
	printf '"streamer":%s' "$(thingino_agent_json_string "$backend")"
	printf '},'
	printf '"backend":{"name":%s,"available":true}' "$(thingino_agent_json_string "$backend")"
	printf '}\n'
}

