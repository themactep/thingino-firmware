#!/bin/sh

show_help() {
	echo "Usage: $0 <mode> <type>
Where:
	mode	on|off
	type	ir850|ir940|white
" >&2
	exit 1
}

[ "$#" -lt 1 ] && show_help

dt_read_u32() {
	local prop="$1" path="/proc/device-tree/thingino_ir/$prop" bytes
	[ -r "$path" ] || return 1
	bytes=$(od -An -N4 -tx1 "$path" 2>/dev/null | tr -d ' \n')
	[ "${#bytes}" -eq 8 ] || return 1
	printf '%d\n' "$((16#$bytes))"
}

dt_pin_token() {
	local pin_prop="$1" active_prop="$2" pin active
	pin=$(dt_read_u32 "$pin_prop" 2>/dev/null) || return 1
	active=$(dt_read_u32 "$active_prop" 2>/dev/null || echo 0)
	if [ "$active" -eq 1 ]; then
		printf '%so\n' "$pin"
	else
		printf '%sO\n' "$pin"
	fi
}

[ -n "$gpio_ir850" ] || gpio_ir850=$(dt_pin_token ir850-pin ir850-active-low)
[ -n "$gpio_ir940" ] || gpio_ir940=$(dt_pin_token ir940-pin ir940-active-low)
[ -n "$gpio_white" ] || gpio_white=$(dt_pin_token white-pin white-active-low)

# set parameters from cli, if empty
[ -z "$mode" ] && mode=$1
[ -z "$type" ] && type=$2

case "$type" in
	ir850)
		pin=$gpio_ir850
		;;
	ir940)
		pin=$gpio_ir940
		;;
	white)
		pin=$gpio_white
		;;
	*)
		# select first non-empty pin of available
		[ -z "$pin" ] && pin=$gpio_ir850
		[ -z "$pin" ] && pin=$gpio_ir940
		[ -z "$pin" ] && pin=$gpio_white
		;;
esac

if [ -z "$pin" ]; then
	echo "Please define LED GPIO pin" >&2
	exit 1
fi

# default to output high
case "$pin" in
	*[!0-9]*) ;;
	*) pin="${pin}O" ;;
esac

pin_last=$(printf '%s' "$pin" | tail -c 1)
case "$pin_last" in
	o)
		pin_on=0
		pin_off=1
		;;
	O)
		pin_on=1
		pin_off=0
		;;
esac
pin=${pin%?}

case "$mode" in
	0 | off)
		gpio set $pin $pin_off
		;;
	1 | on)
		gpio set $pin $pin_on
		;;
	~ | toggle)
		gpio toggle $pin
		;;
	\? | read | status)
		if [ "$(gpio value $pin | tr -d '\n')" = "$pin_on" ]; then
			echo -n "1"
		else
			echo -n "0"
		fi
		;;
	*)
		echo "Error: Unknown mode" >&2
		exit 1
		;;
esac

exit 0
