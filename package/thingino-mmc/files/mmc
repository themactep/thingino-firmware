#!/bin/sh

if [ -z "$1" ]; then
	echo "Usage: $0 <mmc port> [-r]" >&2
	exit 1
fi

endpoint=""
for candidate in \
	"/sys/class/mmc_host/mmc$1/device/present" \
	"/sys/devices/platform/jzmmc_v1.2.$1/present"; do
	if [ -f "$candidate" ]; then
		endpoint="$candidate"
		break
	fi
done

if [ -z "$endpoint" ]; then
	echo "No present endpoint for MMC$1" >&2
	exit 1
fi

# Do REMOVE if -r supplied, otherwise INSERT
if [ "$2" = "-r" ]; then
	action="REMOVE"
else
	action="INSERT"
fi
echo "$action" >"$endpoint"

exit 0
