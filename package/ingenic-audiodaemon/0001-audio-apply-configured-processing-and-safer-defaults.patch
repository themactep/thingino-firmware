diff -urN orig/src/iad/audio/input.c new/src/iad/audio/input.c
--- orig/src/iad/audio/input.c	2025-04-28 19:34:25.000000000 -0400
+++ new/src/iad/audio/input.c	2026-03-21 16:32:05.493001827 -0400
@@ -15,6 +15,82 @@
 #define TRUE 1
 #define TAG "AI"

+static int get_config_bool(cJSON *item, int default_value) {
+    if (!item) {
+        return default_value;
+    }
+    if (cJSON_IsTrue(item)) {
+        return 1;
+    }
+    if (cJSON_IsFalse(item)) {
+        return 0;
+    }
+    if (cJSON_IsNumber(item)) {
+        return item->valueint != 0;
+    }
+    return default_value;
+}
+
+static int clamp_config_int(cJSON *item, int default_value, int min_value, int max_value, const char *name) {
+    int value;
+
+    if (!item || !cJSON_IsNumber(item)) {
+        return default_value;
+    }
+
+    value = item->valueint;
+    if (value < min_value || value > max_value) {
+        IMP_LOG_ERR(TAG, "%s value out of range: %d. Using default value: %d.\n", name, value, default_value);
+        return default_value;
+    }
+
+    return value;
+}
+
+static void log_processing_error(const char *feature, int ret) {
+    if (ret != 0) {
+        IMP_LOG_ERR(TAG, "%s failed: %d\n", feature, ret);
+    }
+}
+
+static void apply_input_processing(int aiDevID, int aiChnID, const IMPAudioIOAttr *attr) {
+    cJSON *alcGainItem = get_audio_attribute(AUDIO_INPUT, "SetAlcGain");
+    cJSON *enableNsItem = get_audio_attribute(AUDIO_INPUT, "Enable_Ns");
+    cJSON *levelNsItem = get_audio_attribute(AUDIO_INPUT, "Level_Ns");
+    cJSON *enableHpfItem = get_audio_attribute(AUDIO_INPUT, "Enable_Hpf");
+    cJSON *enableAecItem = get_audio_attribute(AUDIO_INPUT, "EnableAec");
+    cJSON *enableAgcItem = get_audio_attribute(AUDIO_INPUT, "Enable_Agc");
+    cJSON *agcAttributes = get_audio_attribute(AUDIO_INPUT, "AGC_attributes");
+    int enableAec = get_config_bool(enableAecItem, 0);
+
+#ifndef CONFIG_T20
+    log_processing_error("IMP_AI_SetAlcGain", IMP_AI_SetAlcGain(aiDevID, aiChnID, clamp_config_int(alcGainItem, 2, 0, 7, "SetAlcGain")));
+#endif
+
+    if (enableAec) {
+        int aoDevID, aoChnID;
+        get_audio_output_device_attributes(&aoDevID, &aoChnID);
+        log_processing_error("IMP_AI_EnableAec", IMP_AI_EnableAec(aiDevID, aiChnID, aoDevID, aoChnID));
+        return;
+    }
+
+    if (get_config_bool(enableNsItem, 0)) {
+        log_processing_error("IMP_AI_EnableNs", IMP_AI_EnableNs((IMPAudioIOAttr *) attr, clamp_config_int(levelNsItem, 1, 0, 3, "Level_Ns")));
+    }
+
+    if (get_config_bool(enableHpfItem, 0)) {
+        log_processing_error("IMP_AI_EnableHpf", IMP_AI_EnableHpf((IMPAudioIOAttr *) attr));
+    }
+
+    if (get_config_bool(enableAgcItem, 0) && agcAttributes && cJSON_IsObject(agcAttributes)) {
+        IMPAudioAgcConfig agcConfig;
+        agcConfig.TargetLevelDbfs = clamp_config_int(cJSON_GetObjectItemCaseSensitive(agcAttributes, "TargetLevelDbfs"), 0, 0, 31, "TargetLevelDbfs");
+        agcConfig.CompressionGaindB = clamp_config_int(cJSON_GetObjectItemCaseSensitive(agcAttributes, "CompressionGaindB"), 6, 0, 90, "CompressionGaindB");
+        log_processing_error("IMP_AI_SetAgcMode", IMP_AI_SetAgcMode(kAgcModeFixedDigital));
+        log_processing_error("IMP_AI_EnableAgc", IMP_AI_EnableAgc((IMPAudioIOAttr *) attr, agcConfig));
+    }
+}
+
 /**
  * Initializes the audio input device with the specified attributes.
  *
@@ -104,6 +180,8 @@
         handle_audio_error("Failed to set gain attribute");
     }

+    apply_input_processing(aiDevID, aiChnID, &attr);
+
     // Debugging prints
     printf("[INFO] AI samplerate: %d\n", attr.samplerate);
     printf("[INFO] AI Volume: %d\n", vol);
