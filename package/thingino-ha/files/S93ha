#!/bin/sh

DAEMON="ha-daemon"
LOGFILE="/tmp/ha-daemon.log"

. /usr/share/common
. /usr/share/ha-common

read_config() {
	jct /etc/thingino.json get "$1" 2>/dev/null
}

ha_processes_gone() {
	local proc
	for proc in ha-daemon ha-commands ha-discovery ha-state; do
		if pidof "$proc" >/dev/null 2>&1; then
			return 1
		fi
	done
	if [ -n "$HA_CAMERA_ID" ]; then
		if pgrep -f "mosquitto_.*${HA_CAMERA_ID}" >/dev/null 2>&1; then
			return 1
		fi
	fi
	return 0
}

wait_for_ha_shutdown() {
	local timeout=20
	while [ "$timeout" -gt 0 ]; do
		ha_processes_gone && return 0
		sleep 1
		timeout=$((timeout - 1))
	done
	return 1
}

start() {
	echo_title "Starting HA daemon"

	if [ "true" != $(read_config "ha.enabled") ]; then
		echo_error "Disabled"
		exit 1
	else
		echo_info "Enabled"
	fi

	host=$(read_config "ha.mqtt.host")
	if [ -z "$host" ]; then
		echo_error "HA MQTT host is not configured"
		exit 1
	else
		echo_info "HA MQTT host: $host"
	fi

	start_daemon
}

stop() {
	echo_title "Stopping HA daemon"

	stop_daemon
	killall -q ha-daemon ha-commands ha-discovery ha-state 2>/dev/null
	if [ -n "$HA_CAMERA_ID" ]; then
		pkill -f "mosquitto_.*${HA_CAMERA_ID}" 2>/dev/null
	fi
	if ! wait_for_ha_shutdown; then
		killall -q -9 ha-daemon ha-commands ha-discovery ha-state 2>/dev/null
		if [ -n "$HA_CAMERA_ID" ]; then
			pkill -9 -f "mosquitto_.*${HA_CAMERA_ID}" 2>/dev/null
		fi
		wait_for_ha_shutdown || true
	fi
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		stop
		start
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
		;;
esac

exit 0
