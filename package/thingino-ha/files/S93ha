#!/bin/sh

DAEMON="ha-daemon"
LOGFILE="/tmp/ha-daemon.log"

. /usr/share/common

read_config() {
	jct /etc/thingino.json get "$1" 2>/dev/null
}

start() {
	echo_title "Starting HA daemon"

  if [ "true" != $(read_config "ha.enabled") ]; then
		echo_error "Disabled"
		exit 1
  else
    echo_info "Enabled"
	fi

  host=$(read_config "ha.mqtt.host")
  if [ -z "$host" ]; then
    echo_error "HA MQTT host is not configured"
    exit 1
  else
    echo_info "HA MQTT host: $host"
  fi

	start_daemon
}

stop() {
	echo_title "Stopping HA daemon"

	stop_daemon
	killall -q ha-state ha-commands 2>/dev/null
	sleep 1
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		stop
		sleep 1
		start
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
		;;
esac

exit 0
