#!/bin/sh
# Home Assistant MQTT integration daemon.
# Publishes discovery, starts command subscriber, polls state periodically.
# Config: /etc/thingino.json under "ha" key — see /usr/share/ha-common.

. /usr/share/ha-common

[ -n "$HA_CAMERA_ID" ] || { echo "ha-daemon: cannot determine camera MAC" >&2; exit 1; }
[ -n "$HA_MQTT_HOST" ] || { echo "ha-daemon: ha.mqtt.host (or mqtt_sub.host) not configured" >&2; exit 1; }

# ---------------------------------------------------------------------------
# Singleton: only one ha-daemon may run at a time.
# Use mkdir for an atomic test-and-set — unlike a plain file check+write,
# mkdir either succeeds (we own the lock) or fails (someone else does),
# with no window between the two steps.
# ---------------------------------------------------------------------------
HA_LOCK_DIR="/run/ha/daemon.lock.d"
mkdir -p /run/ha
if ! mkdir "$HA_LOCK_DIR" 2>/dev/null; then
	old_pid=$(cat "${HA_LOCK_DIR}/pid" 2>/dev/null)
	if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
		echo "ha-daemon: previous instance (pid $old_pid) still alive, waiting..." >&2
		kill "$old_pid" 2>/dev/null
		timeout=10
		while kill -0 "$old_pid" 2>/dev/null && [ "$timeout" -gt 0 ]; do
			sleep 1
			timeout=$((timeout - 1))
		done
		if kill -0 "$old_pid" 2>/dev/null; then
			echo "ha-daemon: previous instance did not exit, killing..." >&2
			kill -9 "$old_pid" 2>/dev/null
		fi
	fi
	# Stale lock from a previous crash — take it over
	rm -rf "$HA_LOCK_DIR"
	mkdir "$HA_LOCK_DIR" 2>/dev/null || { echo "ha-daemon: cannot acquire lock" >&2; exit 1; }
fi
printf '%s\n' "$$" > "${HA_LOCK_DIR}/pid"

# ---------------------------------------------------------------------------
# Clear state cache on startup.
# This ensures the first ha-state call (with "force") publishes all entity
# values to fully sync Home Assistant, even if the camera was previously
# running and had a populated cache.
# ---------------------------------------------------------------------------
ha_state_cache_clear

# ---------------------------------------------------------------------------
# Publish discovery and start command subscriber
# ---------------------------------------------------------------------------
ha-discovery || { echo "ha-daemon: discovery failed" >&2; exit 1; }

# Restart ha-commands automatically if it exits (e.g. transient broker disconnect).
# Backoff doubles on each crash (5s → 10s → ... → 300s max).
# Backoff resets if ha-commands ran for more than 60s — indicates a healthy
# connection that dropped transiently rather than a crash loop at startup.
run_commands() {
	local mpub delay=5 max_delay=300 start_time elapsed
	while true; do
		start_time=$(date +%s)
		ha-commands
		elapsed=$(( $(date +%s) - start_time ))
		if [ "$elapsed" -ge 60 ]; then
			delay=5
		fi
		echo "ha-daemon: ha-commands exited after ${elapsed}s, restarting in ${delay}s..." >&2
		sleep "$delay"
		delay=$((delay * 2))
		[ "$delay" -gt "$max_delay" ] && delay="$max_delay"
		mpub=$(ha_mpub_cmd daemon)
		sh -c "$mpub -r -t '${HA_AVAIL_TOPIC}' -m 'online'" 2>/dev/null
	done
}
run_commands &
CMD_PID=$!

# First ha-state call: force-publish all entities to fully sync HA.
# Subsequent calls in the loop below only publish changed values.
ha-state force

# ---------------------------------------------------------------------------
# Cleanup on exit
# ---------------------------------------------------------------------------
cleanup() {
	local mpub
	mpub=$(ha_mpub_cmd daemon)
	sh -c "$mpub -r -t '${HA_AVAIL_TOPIC}' -m 'offline'" 2>/dev/null
	kill "$CMD_PID" 2>/dev/null
	wait "$CMD_PID" 2>/dev/null
	rm -rf "$HA_LOCK_DIR"
}
trap cleanup EXIT INT TERM

# ---------------------------------------------------------------------------
# Periodic state + discovery refresh loop
# ---------------------------------------------------------------------------
STATE_INTERVAL=$(ha_cfg state_interval)
STATE_INTERVAL="${STATE_INTERVAL:-15}"

DISC_INTERVAL=$(ha_cfg discovery_interval)
DISC_INTERVAL="${DISC_INTERVAL:-3600}"

elapsed=0
while true; do
	sleep "$STATE_INTERVAL"
	elapsed=$((elapsed + STATE_INTERVAL))
	# No "force" argument: only publishes entities that changed since last poll.
	ha-state
	if [ "$elapsed" -ge "$DISC_INTERVAL" ]; then
		ha-discovery
		# OTA check aligned with discovery interval
		ha-state force_ota
		elapsed=0
	fi
done
