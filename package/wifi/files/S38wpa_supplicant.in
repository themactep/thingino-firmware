#!/bin/sh

DAEMON_SHORT="wpa_supplicant"
DAEMON_FULL="/usr/sbin/wpa_supplicant"

iface_exists() {
	iface="$1"

	if [ -z "$iface" ]; then
		echo "Interface parameter missing." >&2
		return 1
	fi

	if ip link show $iface >/dev/null 2>&1; then
		echo "Interface '$iface' exists."
		return 0
	else
		echo "Interface '$iface' does not exist."
		return 1
	fi
}

ts() {
	date -u +"%F %T"
}

STA_IFACE=@WLAN_STA_NETDEV@
AP_IFACE=@WLAN_AP_NETDEV@
WLAN_MODULE_NAME="@WLAN_MODULE_NAME@"

CONFIG="/etc/$DAEMON_SHORT.conf"

PORTAL_MODE_FLAG="/run/portal_mode"
PORTAL_CNET=172.16.0
PORTAL_IP=${PORTAL_CNET}.1

WLANAP_MODE_FLAG="/run/wlan_ap_mode"
WLANAP_CNET=100.64.1
WLANAP_IP=${WLANAP_CNET}.1

hostname=$(hostname)

# Determine the wireless mode
if ! grep -q 'ssid=' $CONFIG >/dev/null; then
	echo "WiFi network missing" >&2
	mode="portal"
elif ! grep -q 'psk=' $CONFIG >/dev/null; then
	echo "WiFi password missing" >&2
	mode="portal"
elif grep -q 'mode=2' $CONFIG >/dev/null; then
	mode="ap"
else
	mode="client"
fi

case "$mode" in
	portal | ap)
		IFACE="$AP_IFACE"
		WLAN_INT_FILE="/etc/network/interfaces.d/$STA_IFACE"
		;;
	*)
		IFACE="$STA_IFACE"
		WLAN_INT_FILE="/etc/network/interfaces.d/$STA_IFACE"
		;;
esac

PIDFILE="/run/$DAEMON_SHORT.$IFACE.pid"
DAEMON_ARGS="-i $IFACE -c $CONFIG -P $PIDFILE -B"
if [ "true" = "$debug" ]; then
	DAEMON_ARGS="$DAEMON_ARGS -dd"
fi

credentials_from_card() {
	local envfile ssid password

	envfile="/mnt/mmcblk0p1/uenv.txt"
	[ -f $envfile ] || return 0

	ssid="$(grep '^wlan_ssid=' $envfile | cut -d= -f2-)"
	password="$(grep '^wlan_pass=' $envfile | cut -d= -f2-)"
	wlan configure "$ssid" "$password"
}

timeout() {
	sleep 600 &&
		play /usr/share/sounds/configurationportalisdown.opus &&
		$0 stop
}

prepare_portal() {
	# FIXME: should de done at compile time
	sed -i "s/%dev%/$IFACE/g" /etc/udhcpd-portal.conf

	echo "Prepare Captive Portal"

	echo "Create DHCP leases database"
	touch /run/udhcpd.leases

	echo "Assign ${PORTAL_IP} to $IFACE"
	ip address add ${PORTAL_IP}/24 dev $IFACE

	echo "Bring $IFACE interface up"
	ip link set $IFACE up

	echo "Add route ${PORTAL_CNET}.0/24 to $IFACE"
	ip route add ${PORTAL_CNET}.0/24 dev $IFACE

	# FIXME: should be done in compile time or in tmpfs
	echo "Update SSID with last two octets of MAC address"
	mac_address=$(ip link show $IFACE | awk '/ether/ {print $2}')
	last_two=$(echo $mac_address | awk -F: '{print $(NF-1) $NF}')
	sed -i "/ssid=\"THINGINO-\"$/ s/\"$/$last_two\"/" $CONFIG

	echo "Start wpa_supplicant"
	start-stop-daemon -S -x $DAEMON_FULL -- $DAEMON_ARGS 2>&1

	echo "Set $PORTAL_MODE_FLAG"
	touch "$PORTAL_MODE_FLAG"

	echo "Portal prepared at $(ts)"
}

finish_portal() {
	echo "Start DHCP server"
	start-stop-daemon -S -x /sbin/udhcpd -- -S -I $PORTAL_IP /etc/udhcpd-portal.conf

	echo "Start DNS server"
	start-stop-daemon -S -x /sbin/dnsd -- -i $PORTAL_IP -c /etc/dnsd-portal.conf -d

	echo "Portal started at $(ts)"
	play /usr/share/sounds/configurationportalisup.opus

	echo "Start timeout countdown"
	timeout &
}

stop_portal() {
	echo -c 15 "Captive Portal"

	echo "Stop udhcp"
	start-stop-daemon -K -q -x /sbin/udhcpd

	echo "Stop dnsd"
	start-stop-daemon -K -q -x /sbin/dnsd

	echo "Stop wpa_supplicant"
	start-stop-daemon -K -q -x $DAEMON_FULL

	echo "Remove route ${PORTAL_CNET}.0/24 from $IFACE"
	ip route delete ${PORTAL_CNET}.0/24 dev $IFACE

	echo "Remove IP address from $IFACE"
	ip address delete dev $IFACE ${PORTAL_IP}/24

	echo "Bring down $IFACE"
	ip link set $IFACE down

	echo "Remove $PORTAL_MODE_FLAG"
	rm -f "$PORTAL_MODE_FLAG"

	echo "Portal stopped at $(ts)"
}

start_access_point() {
	# Define in the global scope (populated at build time)
	sed -i "s/%dev%/$IFACE/g" /etc/udhcpd-ap.conf

	echo -c 15 "WLAN Access Point"

	echo "Create DHCP leases database"
	touch /run/udhcpd_ap.leases

	echo "Set WLAN AP resolver configuration"
	cp /etc/resolv-ap.conf /tmp/resolv.conf

	echo "Bring $IFACE up"
	ip link set $IFACE up

	echo "Add IP address ${WLANAP_IP}/24 to $IFACE"
	ip address add ${WLANAP_IP}/24 dev $IFACE

	echo "Add route ${WLANAP_CNET}.0/24 to $IFACE"
	ip route add ${WLANAP_CNET}.0/24 dev $IFACE

	echo "Set WLAN AP DNS configuration"
	cp /etc/dnsd-ap.conf /tmp/dnsd.conf
	if ! grep -q "$hostname" /tmp/dnsd.conf; then
		echo "Add ${hostname}.local to DNS configuration"
		echo $hostname.local $WLANAP_IP >>/tmp/dnsd.conf
	fi

	echo "Start wpa_supplicant"
	start-stop-daemon -S -x $DAEMON_FULL -- $DAEMON_ARGS 2>&1

	echo "Start udhcpd"
	start-stop-daemon -S -x /sbin/udhcpd -- -S -I $WLANAP_IP /etc/udhcpd-ap.conf

	echo "Start dnsd"
	start-stop-daemon -S -x /sbin/dnsd -- -i $WLANAP_IP -c /tmp/dnsd.conf -d

	echo "WLAN Access Point started"
	touch "$WLANAP_MODE_FLAG"
}

stop_access_point() {
	echo -c 15 "WLAN Access Point"

	echo "Stop udhcpd"
	start-stop-daemon -K -q -x /sbin/udhcpd

	echo "Stop dnsd"
	start-stop-daemon -K -q -x /sbin/dnsd

	echo "Stop wpa_supplicant"
	start-stop-daemon -K -q -x $DAEMON_FULL

	echo "Remove IP address from $IFACE"
	ip address delete dev $IFACE ${WLANAP_IP}/24

	echo "Bring down $IFACE"
	ip link set $IFACE down

	echo "WLAN Access Point stopped"
	rm -f "$WLANAP_MODE_FLAG"
}

start_client() {
	echo "Start wpa_supplicant"
	start-stop-daemon -S -x $DAEMON_FULL -- $DAEMON_ARGS 2>&1
}

stop_client() {
	echo "Stop wpa_supplicant"
	start-stop-daemon -K -q -x $DAEMON_FULL
	if [ -f /var/run/udhcpc.${IFACE}.pid ]; then
		kill $(cat /var/run/udhcpc.${IFACE}.pid) 2>/dev/null
		sleep 1
	fi
	ip addr flush dev $IFACE 2>/dev/null
}

start() {
	# Credential from SD card
	credentials_from_card

	echo -c 15 "Starting WPA Supplicant"

	# Interface is not present
	if iface_exists "$IFACE"; then
		echo "Found $IFACE interface"
	else
		echo "Wireless interface $IFACE not found" >&2
		exit 1
	fi

	# Interface is present but disabled
	if grep -q "^#auto $IFACE" $WLAN_INT_FILE; then
		echo "$IFACE manually disabled" >&2
		exit 1
	else
		echo "$IFACE is enabled"
	fi

	echo "Starting in $mode mode"
	case "$mode" in
		portal) prepare_portal ;;
		ap) start_access_point ;;
		*) start_client ;;
	esac
}

stop() {
	echo -c 15 "Stopping WPA Supplicant"

	case "$mode" in
		portal) stop_portal ;;
		ap) stop_access_point ;;
		*) stop_client ;;
	esac
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		stop
		start
		;;
	portal_confirmed)
		finish_portal
		;;
	*)
		echo "Usage: $0 {start|stop|restart}" >&2
		exit 1
		;;
esac

exit 0
