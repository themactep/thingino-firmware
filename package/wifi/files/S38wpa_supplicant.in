#	fi
#	wpa_cli -i $IFACE save_config >/dev/null
#	wpa_cli -i $IFACE reassociate >/dev/null
#}

start_client() {
        echo_info "Start wpa_supplicant"
	start-stop-daemon -S -x $DAEMON_FULL -- $DAEMON_ARGS 2>&1
}

stop_client() {
	echo_info "Stop wpa_supplicant"
	start-stop-daemon -K -q -x /sbin/wpa_supplicant
}

start() {
	# Credential from SD card
	credentials_from_card

	echo_title "Starting WPA Supplicant"

	# Interface is not present
	if iface_exists "$IFACE"; then
		echo_info "Found $IFACE interface"
	else
                echo_error "Wireless interface $IFACE not found"
                exit 1
        fi

	# Interface is present but disabled
	if grep -q "^#auto $IFACE" $WLAN_INT_FILE; then
		echo_error "$IFACE manually disabled"
		exit 1
	else
		echo_info "$IFACE is enabled"
	fi

	# Wired interface is present
        #if iface_exists "eth0"; then
        #        echo_error "Wired interface found"
        #        exit 1
        #fi
        #if iface_exists "usb0"; then
        #        echo_error "Wired interface found"
        #        exit 1
        #fi

	echo_info "Starting in $mode mode"
	case "$mode" in
		portal) start_portal ;;
		ap) start_access_point ;;
		*) start_client	;;
	esac
}

stop() {
	echo_title "Stopping WPA Supplicant"

	case "$mode" in
		portal) stop_portal ;;
		ap) stop_access_point ;;
		*) stop_client	;;
	esac
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		stop
		start
		;;
	*)
		echo "Usage: $0 {start|stop|restart}" >&2
		exit 1
		;;
esac

exit 0
