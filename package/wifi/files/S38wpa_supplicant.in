#	# Use wpa_cli to update network without restarting
#	wpa_cli -i $IFACE set_network 0 ssid "\"$wlan_ssid\"" >/dev/null
#	wpa_cli -i $IFACE set_network 0 psk "$wlan_psk" >/dev/null
