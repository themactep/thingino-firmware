#!/bin/sh

WLAN_MODULE_NAME="@WLAN_MODULE_NAME@"

unload_wlan_module() {
	[ -n "$WLAN_MODULE_NAME" ] || return 0

	if grep -q "^$WLAN_MODULE_NAME\b" /proc/modules; then
		echo "Unloading WLAN module $WLAN_MODULE_NAME" >&2
		if rmmod "$WLAN_MODULE_NAME"; then
			echo "Unloaded $WLAN_MODULE_NAME" >&2
		else
			echo "Failed to unload $WLAN_MODULE_NAME" >&2
		fi
	fi
}

has_wired_uplink() {
	local iface="$1"

	[ -z "$iface" ] && return 1
	ip link show "$iface" >/dev/null 2>&1 || return 1
	ip -4 route show default dev "$iface" | grep -q . && return 0
	ip -6 route show default dev "$iface" | grep -q . && return 0
	return 1
}

case "$1" in
	start)
		attempt=0
		while [ "$attempt" -lt 10 ]; do
			for iface in eth0 usb0; do
				if has_wired_uplink "$iface"; then
					echo "Wired uplink on $iface found, stopping WiFi" >&2
					/etc/init.d/S38wpa_supplicant stop
					/etc/init.d/S36wireless stop
					unload_wlan_module
					exit 0
				fi
			done
			attempt=$((attempt + 1))
			sleep 1
		done
		if [ -f /run/portal_mode ]; then
			/etc/init.d/S38wpa_supplicant portal_confirmed
		fi
		;;
esac

exit 0
