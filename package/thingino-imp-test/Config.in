config BR2_PACKAGE_THINGINO_IMP_TEST
	bool "thingino-imp-test"
	select BR2_PACKAGE_INGENIC_LIB
	select BR2_PACKAGE_INGENIC_MUSL if BR2_TOOLCHAIN_USES_MUSL
	select BR2_PACKAGE_INGENIC_UCLIBC if BR2_TOOLCHAIN_USES_UCLIBC
	help
	  Minimal IMP audio capture test tool.
	  Tests the Ingenic audio input subsystem in isolation.
