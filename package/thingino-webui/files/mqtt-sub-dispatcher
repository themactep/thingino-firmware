#!/bin/sh
# MQTT subscription dispatcher
# Subscribes to configured MQTT topics and executes shell actions on message receipt.
# Environment variables available to action commands:
#   MQTT_TOPIC   - the topic on which the message arrived
#   MQTT_PAYLOAD - the message payload
#
# Topic shorthands (resolved at startup):
#   %hostname - camera hostname
#   %ip       - camera IP address
#   %id       - camera SoC serial number, with MAC-based fallback

CONFIG_FILE="/etc/thingino.json"
HEARTBEAT_INTERVAL="${HEARTBEAT_INTERVAL:-300}"
HEARTBEAT_PID=""

die() {
	echo "$1" >&2
	exit 1
}

json_unquote() {
	value="$1"
	case "$value" in
		\"*\")
			value=$(printf '%s' "$value" | sed -e 's/^"//' -e 's/"$//')
			;;
	esac
	printf '%s' "$value" | sed \
		-e 's/\\"/"/g' \
		-e 's/\\\\/\\/g'
}

start_presence_heartbeat() {
	local register_cmd=""
	if [ -x /usr/sbin/telegram-cam-register ]; then
		register_cmd=/usr/sbin/telegram-cam-register
	elif [ -x /bin/telegram-cam-register ]; then
		register_cmd=/bin/telegram-cam-register
	else
		return 0
	fi

	(
		while :; do
			sleep "$HEARTBEAT_INTERVAL"
			"$register_cmd" online >/dev/null 2>&1 || true
		done
	) &
	HEARTBEAT_PID=$!
}

cleanup() {
	if [ -n "$HEARTBEAT_PID" ]; then
		kill "$HEARTBEAT_PID" >/dev/null 2>&1 || true
		wait "$HEARTBEAT_PID" >/dev/null 2>&1 || true
	fi
}

trap cleanup EXIT INT TERM

camera_id() {
	if command -v soc >/dev/null 2>&1; then
		serial=$(soc -s 2>/dev/null)
		if [ -n "$serial" ]; then
			printf '%s' "$serial"
			return 0
		fi
	fi

	for iface in eth0 wlan0 eth1; do
		addr=$(cat "/sys/class/net/$iface/address" 2>/dev/null | tr -d ':')
		[ -n "$addr" ] && {
			printf '%s' "$addr"
			return 0
		}
	done

	return 1
}

# Resolve camera identity once at startup
CAMERA_HOSTNAME=$(hostname 2>/dev/null)
CAMERA_IP=$(ip route get 1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}' | head -1)
CAMERA_ID=$(camera_id)

expand_topic() {
	printf '%s' "$1" |
		sed -e "s/%hostname/$CAMERA_HOSTNAME/g" \
			-e "s/%ip/$CAMERA_IP/g" \
			-e "s/%id/$CAMERA_ID/g"
}

# Read broker settings
host=$(jct "$CONFIG_FILE" get mqtt_sub.host 2>/dev/null | tr -d '"')
port=$(jct "$CONFIG_FILE" get mqtt_sub.port 2>/dev/null | tr -d '"')
username=$(jct "$CONFIG_FILE" get mqtt_sub.username 2>/dev/null | tr -d '"')
password=$(jct "$CONFIG_FILE" get mqtt_sub.password 2>/dev/null | tr -d '"')
use_ssl=$(jct "$CONFIG_FILE" get mqtt_sub.use_ssl 2>/dev/null)

[ -n "$host" ] || die "mqtt_sub.host is not configured"

port="${port:-1883}"

# Build topic arguments and precompile dispatch rules from enabled
# subscriptions. Doing this once at startup keeps the per-message loop free
# of jct forks — previously the config was re-read (3 jct invocations per
# subscription) for every incoming message, which is expensive on chatty
# topics. Config changes require a service restart, matching the existing
# behavior for broker settings.
TOPICS=""
RULE_COUNT=0
i=0
while true; do
	topic=$(jct "$CONFIG_FILE" get "mqtt_sub.subscriptions.$i.topic" 2>/dev/null | tr -d '"')
	[ -n "$topic" ] || break
	enabled=$(jct "$CONFIG_FILE" get "mqtt_sub.subscriptions.$i.enabled" 2>/dev/null)
	qos=$(jct "$CONFIG_FILE" get "mqtt_sub.subscriptions.$i.qos" 2>/dev/null | tr -d '"')
	if [ "$enabled" = "true" ]; then
		expanded=$(expand_topic "$topic")
		TOPICS="$TOPICS -t $expanded -q ${qos:-0}"

		action=$(jct "$CONFIG_FILE" get "mqtt_sub.subscriptions.$i.action" 2>/dev/null)
		action=$(json_unquote "$action")
		if [ -n "$action" ]; then
			# Convert MQTT wildcards to shell glob patterns
			pattern=$(printf '%s' "$expanded" | sed -e 's/+/[^\/]*/g' -e 's/#/.*/g')
			eval "RULE_PATTERN_$RULE_COUNT=\$pattern"
			eval "RULE_ACTION_$RULE_COUNT=\$action"
			RULE_COUNT=$((RULE_COUNT + 1))
		fi
	fi
	i=$((i + 1))
done

[ -n "$TOPICS" ] || die "No enabled subscriptions configured"

# Assemble mosquitto_sub command
CMD="mosquitto_sub -h $host -p $port -v -F \"%t %p\""
[ -n "$username" ] && CMD="$CMD -u $username"
[ -n "$password" ] && CMD="$CMD -P $password"
[ "$use_ssl" = "true" ] && CMD="$CMD --capath /etc/ssl/certs"
CMD="$CMD $TOPICS"

start_presence_heartbeat

# Run subscriber loop. Matching uses only shell builtins against the rules
# precompiled at startup — no process is forked unless an action fires.
sh -c "$CMD" | while IFS= read -r line; do
	mqtt_topic="${line%% *}"
	mqtt_payload="${line#* }"
	[ -n "$mqtt_topic" ] || continue

	j=0
	while [ "$j" -lt "$RULE_COUNT" ]; do
		eval "pattern=\$RULE_PATTERN_$j"
		eval "action=\$RULE_ACTION_$j"
		case "$mqtt_topic" in
			$pattern)
				MQTT_TOPIC="$mqtt_topic" MQTT_PAYLOAD="$mqtt_payload" sh -c "$action"
				;;
		esac
		j=$((j + 1))
	done
done
