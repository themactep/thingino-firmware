#!/bin/sh

DAEMON="/usr/sbin/recordmgr"
DAEMON_ARGS=""

. /usr/share/common

CONFIG_FILE="/etc/prudynt.json"

cleanup_enabled() {
	local val
	val=$(jct "$CONFIG_FILE" get "recorder.cleanup_enabled" 2>/dev/null)
	[ "$val" = "true" ] || [ "$val" = "1" ]
}

start() {
	echo_title "Starting Recording Storage Manager"

	if ! cleanup_enabled; then
		echo_info "Recording storage manager is disabled"
		return 0
	fi

	start_daemon
}

stop() {
	echo_title "Stopping Recording Storage Manager"

	stop_daemon
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart | reload)
		stop || true
		sleep 1
		start
		;;
	*)
		echo "Usage: $0 {start|stop|restart|reload}"
		exit 1
		;;
esac

exit 0
