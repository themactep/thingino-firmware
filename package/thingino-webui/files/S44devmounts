#!/bin/sh

MOUNT_SHARE=
MOUNT_POINT="/var/www"

start() {
	echo -c 15 "Mounting $MOUNT_SHARE to $MOUNT_POINT"

	if mountpoint -q $MOUNT_POINT; then
		echo "Already mounted" >&2
	fi

	echo "Remove mountpoint $MOUNT_POINT"
	rm -r $MOUNT_POINT

	echo "Create mountpoint $MOUNT_POINT"
	mkdir $MOUNT_POINT

	echo "Mounting $MOUNT_SHARE to $MOUNT_POINT"
	mount -t nfs -o nolock,tcp,nfsvers=3 $MOUNT_SHARE $MOUNT_POINT
}

stop() {
	echo -c 15 "Unmounting $MOUNT_POINT"

	if ! mountpoint -q $MOUNT_POINT; then
		echo "Nothing to unmount" >&2
	fi

	echo "Unmounting $MOUNT_POINT"
	umount $MOUNT_POINT

	echo "Remove whiteout from overlay"
	rm -r /overlay$MOUNT_POINT

	echo "Remount overlay"
	mount -o remount /
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		stop
		sleep 1
		start
		;;
	*)
		echo "Usage: $0 {start|stop}"
		exit 1
		;;
esac

exit 0
