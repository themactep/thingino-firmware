#!/bin/sh

# Heartbeat daemon - runs in background and updates cache continuously
# Start with: /etc/init.d/S99heartbeat start

FAST_CACHE_FILE="/tmp/heartbeat_cache.json"
SLOW_CACHE_FILE="/tmp/heartbeat_slow_cache.json"
UPDATE_INTERVAL=1
SLOW_UPDATE_INTERVAL=15
PIDFILE="/var/run/heartbeat-daemon.pid"

is_prudynt_running() {
  pidof prudynt >/dev/null 2>&1
}

read_first_field() {
  local value _

  if [ -r "$1" ] && read -r value _ < "$1"; then
    printf '%s\n' "$value"
  else
    printf '%s\n' "$2"
  fi
}

parse_prudynt_data() {
  printf '%s\n' "$1" | awk '
    BEGIN {
      color_mode = "null"
      mic_enabled = "false"
      spk_enabled = "false"
      total_gain = "0"
      daynight_enabled = "false"
    }
    {
      if (match($0, /"running_mode":[^,}]*/)) {
        color_mode = substr($0, RSTART + 15, RLENGTH - 15)
      }
      if (match($0, /"mic_enabled":[^,}]*/)) {
        mic_enabled = substr($0, RSTART + 14, RLENGTH - 14)
      }
      if (match($0, /"spk_enabled":[^,}]*/)) {
        spk_enabled = substr($0, RSTART + 14, RLENGTH - 14)
      }
      if (match($0, /"total_gain":[0-9-]*/)) {
        total_gain = substr($0, RSTART + 13, RLENGTH - 13)
      }
      if (match($0, /"daynight":\{"enabled":[^,}]*/)) {
        daynight_enabled = substr($0, RSTART + 22, RLENGTH - 22)
      }
    }
    END {
      printf "%s|%s|%s|%s|%s\n", color_mode, mic_enabled, spk_enabled, total_gain, daynight_enabled
    }
  '
}

start() {
  if [ ! -f "/bin/prudynt" ]; then
    echo "Prudynt not found. Exiting"
    return 0
  fi

  if ! is_prudynt_running; then
    echo "Prudynt is not running. Exiting"
    return 0
  fi

  if [ -f "$PIDFILE" ] && kill -0 $(cat "$PIDFILE") 2>/dev/null; then
    echo "Heartbeat daemon already running"
    return 0
  fi

  echo "Starting heartbeat daemon..."
  heartbeat_loop &
  echo $! > "$PIDFILE"
}

stop() {
  if [ -f "$PIDFILE" ]; then
    echo "Stopping heartbeat daemon..."
    kill $(cat "$PIDFILE") 2>/dev/null
    rm -f "$PIDFILE"
  fi
}

heartbeat_loop() {
  slow_counter=0

  while true; do
    if ! is_prudynt_running; then
      rm -f "$PIDFILE"
      exit 0
    fi

    ch0_rec="false"; [ -f "/run/prudynt/mp4ctl-ch0.active" ] && ch0_rec="true"
    ch1_rec="false"; [ -f "/run/prudynt/mp4ctl-ch1.active" ] && ch1_rec="true"
    motion_enabled="false"; [ -f "/run/prudynt/motion.active" ] && motion_enabled="true"
    privacy_enabled="false"; [ -f "/run/prudynt/privacy.active" ] && privacy_enabled="true"

    # Single prudyntctl call
    prudynt_data=$(prudyntctl json - 2>/dev/null <<'EOF'
{
  "image": {"running_mode": null},
  "audio": {"mic_enabled": null, "spk_enabled": null},
  "daynight": {"status": null, "enabled": null}
}
EOF
)

    parsed_prudynt=$(parse_prudynt_data "$prudynt_data")
    old_ifs=$IFS
    set -f
    IFS='|'
    set -- $parsed_prudynt
    IFS=$old_ifs
    set +f

    color_mode=${1:-null}
    mic_enabled=${2:-false}
    spk_enabled=${3:-false}
    total_gain=${4:-0}
    daynight_enabled=${5:-false}

    printf '{"time_now":%s,"daynight_brightness":"%s","total_gain":%s,"daynight_mode":"%s","rec_ch0":%s,"rec_ch1":%s,"motion_enabled":%s,"privacy_enabled":%s,"color_mode":%s,"mic_enabled":%s,"spk_enabled":%s,"daynight_enabled":%s}' \
      "$(date +%s)" \
      "$(read_first_field /run/prudynt/daynight_brightness "unknown")" \
      "$total_gain" \
      "$(read_first_field /run/prudynt/daynight_mode "unknown")" \
      "$ch0_rec" \
      "$ch1_rec" \
      "$motion_enabled" \
      "$privacy_enabled" \
      "${color_mode:-null}" \
      "${mic_enabled:-false}" \
      "${spk_enabled:-false}" \
      "${daynight_enabled:-false}" > "$FAST_CACHE_FILE.tmp"
    printf '\n' >> "$FAST_CACHE_FILE.tmp"

    mv "$FAST_CACHE_FILE.tmp" "$FAST_CACHE_FILE"

    if [ "$slow_counter" -le 0 ]; then
      ircut_state=$(ircut read 2>/dev/null || echo "null")
      ir850_state=$(light ir850 read 2>/dev/null || echo "null")
      ir940_state=$(light ir940 read 2>/dev/null || echo "null")
      white_state=$(light white read 2>/dev/null || echo "null")

      wg_status=0
      if command -v wg >/dev/null 2>&1; then
        case "$(wg show wg0 2>/dev/null)" in
          *"latest handshake"*) wg_status=1 ;;
        esac
      fi

      printf '{"ircut_state":%s,"ir850_state":%s,"ir940_state":%s,"white_state":%s,"wg_status":%s}' \
        "${ircut_state}" \
        "${ir850_state}" \
        "${ir940_state}" \
        "${white_state}" \
        "$wg_status" > "$SLOW_CACHE_FILE.tmp"
      printf '\n' >> "$SLOW_CACHE_FILE.tmp"

      mv "$SLOW_CACHE_FILE.tmp" "$SLOW_CACHE_FILE"
      slow_counter=$SLOW_UPDATE_INTERVAL
    fi

    slow_counter=$((slow_counter - 1))
    sleep "$UPDATE_INTERVAL"
  done
}

case "$1" in
  start)
    start
    ;;
  stop)
    stop
    ;;
  restart)
    stop
    sleep 1
    start
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac
