#!/bin/sh

[ -r /etc/default/uhttpd ] && . /etc/default/uhttpd

DAEMON="uhttpd"
PIDFILE="/var/run/uhttpd.pid"
PORTAL_MODE_FLAG="/run/portal_mode"

UHTTPD_DOCROOT="${UHTTPD_DOCROOT:-/var/www}"
UHTTPD_PORTAL_DOCROOT="${UHTTPD_PORTAL_DOCROOT:-/var/www-portal}"
UHTTPD_CGI_PREFIX="${UHTTPD_CGI_PREFIX:-/x}"
UHTTPD_COMMON_ARGS="${UHTTPD_COMMON_ARGS:--t 0 -T 15 -k 10 -n 20 -N 100}"
UHTTPD_HTTP_LISTEN="${UHTTPD_HTTP_LISTEN:-80}"
UHTTPD_HTTPS_LISTEN="${UHTTPD_HTTPS_LISTEN:-443}"
UHTTPD_PORTAL_HTTP_LISTEN="${UHTTPD_PORTAL_HTTP_LISTEN:-172.16.0.1:80}"
UHTTPD_ERROR_HANDLER="${UHTTPD_ERROR_HANDLER:-/x/legacy-url-recovery.cgi}"

build_uhttpd_args() {
	local docroot="$1"
	local listen_http="$2"
	local listen_https="$3"
	local error_handler="$4"
	local args="-h $docroot -x $UHTTPD_CGI_PREFIX $UHTTPD_COMMON_ARGS"

	if [ -n "$listen_https" ]; then
		args="$args -s $listen_https -C $cert_path -K $key_path"
	fi

	if [ -n "$listen_http" ]; then
		args="$args -p $listen_http"
	fi

	if [ -n "$error_handler" ]; then
		args="$args -E $error_handler"
	fi

	if [ -n "$EXTRA_ARGS" ]; then
		args="$args $EXTRA_ARGS"
	fi

	echo "$args"
}

start() {
	local display_hostname

	display_hostname="$(hostname 2>/dev/null)"
	[ -z "$display_hostname" ] && display_hostname="localhost"
	case "$display_hostname" in
		*.local) ;;
		*) display_hostname="${display_hostname}.local" ;;
	esac

	# Check if already running - verify PID file contains a valid running process
	if [ -f $PIDFILE ]; then
		local pid=$(cat $PIDFILE)
		if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
			echo "uhttpd already running (PID: $pid)"
			return 0
		else
			echo "Stale PID file found, removing"
			rm -f $PIDFILE
		fi
	fi

	# Portal mode: bind to portal IP, use error handler for captive portal detection
	if [ -f "$PORTAL_MODE_FLAG" ]; then
		echo -c 15 "Starting uhttpd with Portal interface"

		if [ ! -d "$UHTTPD_PORTAL_DOCROOT" ]; then
			echo "Portal directory $UHTTPD_PORTAL_DOCROOT not found"
			return 1
		fi

		DAEMON_ARGS_HTTP="$(build_uhttpd_args "$UHTTPD_PORTAL_DOCROOT" "$UHTTPD_PORTAL_HTTP_LISTEN" "" "/x/portal.cgi")"

		echo "Starting uhttpd with args: $DAEMON_ARGS_HTTP"
		/usr/bin/$DAEMON $DAEMON_ARGS_HTTP 2>&1 &
		local uhttpd_pid=$!
		echo $uhttpd_pid >$PIDFILE

		sleep 3

		if pgrep uhttpd >/dev/null 2>&1; then
			if netstat -ln | grep -q "172.16.0.1:80.*LISTEN"; then
				echo "uhttpd started successfully (Portal mode)"
				echo "Portal: http://172.16.0.1/"
				return 0
			else
				echo "uhttpd running but not listening on 172.16.0.1:80"
				netstat -ln | grep ":80"
				return 1
			fi
		else
			echo "uhttpd process not running"
			return 1
		fi
	else
		echo -c 15 "Starting uhttpd"
	fi

	# SSL certificate paths (generated by S02ssl)
	cert_path="/etc/ssl/certs/uhttpd.crt"
	key_path="/etc/ssl/private/uhttpd.key"

	# Try SSL first if certificates exist
	if [ -f "$cert_path" ] && [ -f "$key_path" ] && [ -s "$cert_path" ] && [ -s "$key_path" ]; then
		echo "SSL certificates found, attempting to start with SSL support..."

		DAEMON_ARGS_SSL="$(build_uhttpd_args "$UHTTPD_DOCROOT" "$UHTTPD_HTTP_LISTEN" "$UHTTPD_HTTPS_LISTEN" "$UHTTPD_ERROR_HANDLER")"

		# Start uhttpd with SSL
		echo "/usr/bin/$DAEMON $DAEMON_ARGS_SSL" >&2
		/usr/bin/$DAEMON $DAEMON_ARGS_SSL >/dev/null 2>&1 &
		local uhttpd_pid=$!
		echo $uhttpd_pid >$PIDFILE

		# Wait and verify both ports are running
		sleep 3

		if pgrep uhttpd >/dev/null 2>&1 && netstat -ln | grep -q ":443.*LISTEN" && netstat -ln | grep -q ":80.*LISTEN"; then
			echo "uhttpd started successfully with SSL support"
			echo "HTTPS: https://$display_hostname:443/"
			echo "HTTP:  http://$display_hostname:80/ (redirects to HTTPS)"
			return 0
		else
			kill "$uhttpd_pid" 2>/dev/null
			echo "SSL startup failed, falling back to HTTP-only..."
		fi
	else
		echo "SSL certificates not available, starting HTTP-only..."
	fi

	# Fallback: HTTP-only mode
	DAEMON_ARGS_HTTP="$(build_uhttpd_args "$UHTTPD_DOCROOT" "$UHTTPD_HTTP_LISTEN" "" "$UHTTPD_ERROR_HANDLER")"

	/usr/bin/$DAEMON $DAEMON_ARGS_HTTP >/dev/null 2>&1 &
	local uhttpd_pid=$!
	echo $uhttpd_pid >$PIDFILE

	# Wait and verify it's running
	sleep 2

	if pgrep uhttpd >/dev/null 2>&1 && netstat -ln | grep -q ":80.*LISTEN"; then
		echo "uhttpd started successfully (HTTP only)"
		echo "HTTP:  http://$display_hostname:80/"
		return 0
	else
		echo "FAIL"
		rm -f $PIDFILE
		return 1
	fi
}

stop() {
	echo -c 15 "Stopping uhttpd"

	# Try to kill using PID file first
	if [ -f $PIDFILE ]; then
		local pid=$(cat $PIDFILE)
		if [ -n "$pid" ] && kill "$pid" 2>/dev/null; then
			echo "Stopped uhttpd (PID: $pid)"
		fi
		rm -f $PIDFILE
	fi

	# Fallback: kill any remaining uhttpd processes
	if pgrep uhttpd >/dev/null 2>&1; then
		echo "Killing remaining uhttpd processes"
		pkill uhttpd 2>/dev/null
		sleep 1
	fi

	# Verify it's stopped
	if pgrep uhttpd >/dev/null 2>&1; then
		echo "Some uhttpd processes may still be running"
	else
		echo "All uhttpd processes stopped"
	fi
}

restart() {
	stop
	sleep 1
	start
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart | reload)
		restart
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
		;;
esac

exit $?
