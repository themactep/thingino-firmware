# uhttpd configuration file
# This file is sourced by the init script

# Debug mode disabled for production (reduces size)
UHTTPD_DEBUG=0

# Enable automatic watchdog monitoring
# Set to 1 to enable, 0 to disable
UHTTPD_WATCHDOG=1

# HTTP-only mode disabled - HTTPS working properly
UHTTPD_DEBUG_HTTP_ONLY=0

# Watchdog configuration (used by uhttpd-watchdog script)
WATCHDOG_INTERVAL=30     # Check interval in seconds
HANG_TIMEOUT=60          # Timeout before considering hung
MAX_RESTARTS=5           # Maximum restarts in time window
RESTART_WINDOW=300       # Time window in seconds (5 minutes)

# SSL debugging disabled for production
SSL_DEBUG=0

# Core listen and request handling profile.
# Default values match the launch profile verified on-device:
# /usr/bin/uhttpd -h /var/www -x /x -t 0 -T 15 -k 10 -n 20 -N 100 -s 443 -C ... -K ... -p 80
UHTTPD_DOCROOT="/var/www"
UHTTPD_PORTAL_DOCROOT="/var/www-portal"
UHTTPD_CGI_PREFIX="/x"
UHTTPD_COMMON_ARGS="-t 0 -T 15 -k 10 -n 20 -N 100"
UHTTPD_HTTP_LISTEN="80"
UHTTPD_HTTPS_LISTEN="443"
UHTTPD_PORTAL_HTTP_LISTEN="172.16.0.1:80"
UHTTPD_ERROR_HANDLER="/x/legacy-url-recovery.cgi"

# Additional uhttpd arguments
# Add any extra arguments here
EXTRA_ARGS=""
