config BR2_PACKAGE_FAAC
	bool "Freeware Advanced Audio Coder"
	help
	  FAAC is an open-source MPEG-2 and MPEG-4 AAC audio format encoder.

	  http://sourceforge.net/projects/faac/

config BR2_PACKAGE_FAAC_INSTALL_BIN
	bool "Install faac CLI"
	default n
	depends on BR2_PACKAGE_FAAC
	help
	  Install the `faac` command-line encoder binary on both the
	  target rootfs and the staging sysroot. Disable this option to
	  keep only the libraries.
