#!/bin/sh

NAME="Telegram Bot daemon"
DAEMON="/usr/sbin/telegrambot"
PIDFILE="/run/telegrambot.pid"
PORTAL_MODE_FLAG="/run/portal_mode"

# The bot always runs in the foreground: backgrounding and pid tracking are
# handled here. -N 15 keeps a chat integration from ever competing with the
# streamer/ISP for CPU.
start_daemon() {
	start-stop-daemon -S -b -m -N 15 -p "$PIDFILE" -x "$DAEMON"
}

daemon_running() {
	start-stop-daemon -K -t -q -x "$DAEMON" 2>/dev/null
}

wait_for_exit() {
	# Wait up to ~10s for every daemon instance to terminate
	local i=0
	while daemon_running; do
		i=$((i + 1))
		[ "$i" -gt 10 ] && return 1
		sleep 1
	done
	return 0
}

stop_daemon() {
	if [ -f "$PIDFILE" ]; then
		start-stop-daemon -K -p "$PIDFILE" -x "$DAEMON"
	fi

	# Catch instances a stale pidfile does not cover
	if daemon_running; then
		start-stop-daemon -K -x "$DAEMON"
	fi

	if ! wait_for_exit; then
		start-stop-daemon -K -s 9 -x "$DAEMON"
		wait_for_exit
	fi
	rm -f "$PIDFILE"
}

start() {
	echo "Starting $NAME"

	if [ -f "$PORTAL_MODE_FLAG" ]; then
		echo "Disabled" >&2
		exit 1
	fi

	# Only start if a bot token has been configured
	local token
	token=$(jct /etc/telegrambot.json get token 2>/dev/null)
	if [ -z "$token" ]; then
		echo "Skipped: no bot token configured" >&2
		exit 0
	fi

	if daemon_running; then
		echo "Already running" >&2
		exit 0
	fi

	start_daemon
}

stop() {
	echo "Stopping $NAME"

	stop_daemon
}

status() {
	if [ -f "$PIDFILE" ] && kill -0 $(cat "$PIDFILE" 2>/dev/null) 2>/dev/null; then
		echo "$NAME is running (pid $(cat "$PIDFILE"))"
		return 0
	fi
	if pidof "$(basename "$DAEMON")" >/dev/null 2>&1; then
		echo "$NAME is running (pid $(pidof "$(basename "$DAEMON")"))"
		return 0
	fi
	echo "$NAME is not running"
	return 3
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		stop
		sleep 1
		start
		;;
	status)
		status
		;;
	*)
		echo "Usage: $0 {start|stop|restart|status}"
		exit 1
		;;
esac

exit 0
