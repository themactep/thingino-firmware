#!/bin/sh

NAME="Telegram Bot daemon"
DAEMON="/usr/sbin/telegrambot"
PIDFILE="/run/telegrambot.pid"
PORTAL_MODE_FLAG="/run/portal_mode"

start_daemon() {
	start-stop-daemon -S -b -m -p "$PIDFILE" -x "$DAEMON"
}

stop_daemon() {
	if [ -f "$PIDFILE" ]; then
		start-stop-daemon -K -p "$PIDFILE" -x "$DAEMON"
		status=$?
		rm -f "$PIDFILE"
		return $status
	fi

	start-stop-daemon -K -x "$DAEMON"
}

start() {
	echo "Starting $NAME"

	if [ -f "$PORTAL_MODE_FLAG" ]; then
		echo "Disabled" >&2
		exit 1
	fi

	start_daemon
}

stop() {
	echo "Stopping $NAME"

	stop_daemon
}

status() {
	if [ -f "$PIDFILE" ] && kill -0 $(cat "$PIDFILE" 2>/dev/null) 2>/dev/null; then
		echo "$NAME is running (pid $(cat "$PIDFILE"))"
		return 0
	fi
	if pidof "$(basename "$DAEMON")" >/dev/null 2>&1; then
		echo "$NAME is running (pid $(pidof "$(basename "$DAEMON")"))"
		return 0
	fi
	echo "$NAME is not running"
	return 3
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		stop
		sleep 1
		start
		;;
	status)
		status
		;;
	*)
		echo "Usage: $0 {start|stop|restart|status}"
		exit 1
		;;
esac

exit 0
