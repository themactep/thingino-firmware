config BR2_PACKAGE_THINGINO_WPA_SUPPLICANT
	bool "Thingino wpa_supplicant overrides"
	depends on BR2_PACKAGE_WPA_SUPPLICANT
	default y
	help
	  Apply Thingino-specific overrides to wpa_supplicant. This
	  disables unused features (smartcard, PKCS12, IEEE80211R,
	  IEEE80211AC/AX, P2P, TDLS, MATCH_IFACE, debug file) and
	  enables Thingino-specific defaults.

if BR2_PACKAGE_THINGINO_WPA_SUPPLICANT

config BR2_PACKAGE_THINGINO_WPA_SUPPLICANT_ROAMING
	bool "Enable wpa_supplicant roaming (disable driver roaming)"
	select BR2_PACKAGE_WPA_SUPPLICANT_AUTOSCAN
	help
	  Enable wpa_supplicant-based roaming and disable internal
	  driver roaming. This allows wpa_supplicant to manage roaming
	  decisions using bgscan, which is generally more reliable than
	  driver-based roaming. Automatically enables autoscan support.

endif
