+#ifdef CONFIG_T41_VENDOR_PAD_INIT
+/*
+ * Normalize the CPM clock-gate/CDR and USB-PHY register state to what
+ * the stock DML16-Z533 U-Boot leaves behind at its prompt (measured
+ * with md.l on both bootloaders on real silicon). Linux inherits much
+ * of this state: with the thingino defaults the SD card never
+ * completes ACMD41 init (stale CE/divider in MSC0CDR) and the
+ * RTL8733BU USB WiFi drops off the bus (USBPCR1/USBVBFIL).
+ */
+static void t41_vendor_cpm_state(void)
+{
+	void __iomem *cpm = (void __iomem *)CPM_BASE;
+
+	/*
+	 * PB pad-config block, reg +0x110 = 0x2f (stock). Without this
+	 * the RTL8733BU drops off the USB bus ~2 s after enumeration.
+	 * The SPL-time write does not stick (cleared during U-Boot
+	 * proper init), so it must be (re)applied here.
+	 */
+	writel(0x0000002f, (void __iomem *)0xb0011110);
+
+	/*
+	 * PB pad attribute reg +0x030: stock clears bits 28/29/30 (pins
+	 * PB28 eth-rst, PB29 wifi-pwr, PB30). Thingino leaves them set,
+	 * which leaves the RTL8733BU power pad marginal -> the chip
+	 * browns out ~4 s after RF starts (all bulk-IN URBs -71 at once).
+	 * Clear bits 29/30 (wifi side) but PRESERVE bit 28 (PB28) so the
+	 * on-chip Ethernet reset stays in the state thingino's dwmac
+	 * driver expects. (Full-vendor value 0x8e7e0000 also clears bit
+	 * 28 and breaks Ethernet on this board.)
+	 */
+	{
+		u32 v = readl((void __iomem *)0xb0011030);
+		v &= ~((1u << 29) | (1u << 30));
+		writel(v, (void __iomem *)0xb0011030);
+	}
+
+	/* pinmux: PA20-22, PA29-31 to device function 1 (stock) */
+	writel(0xe0700000, (void __iomem *)0xb0010044); /* PA PAT0S */
+	writel(0xe0700000, (void __iomem *)0xb0010038); /* PA PAT1C */
+	writel(0xe0700000, (void __iomem *)0xb0010028); /* PA MSKC */
+
+	/* clock gates: stock runs CLKGR0 bit12, CLKGR1 bits 3,17 ungated */
+	clrbits_le32(cpm + 0x20, BIT(12));
+	clrbits_le32(cpm + 0x28, BIT(3) | BIT(17));
+
+	/* CDRs exactly as stock (incl. MSC0CDR cleared of stale CE/div) */
+	writel(0x800000ff, cpm + 0x64);
+	writel(0x00108000, cpm + 0x68);	/* MSC0CDR */
+	writel(0x40108000, cpm + 0x6c);
+	writel(0x001000ff, cpm + 0x70);
+	writel(0x0000007f, cpm + 0x78);
+	writel(0x6000011b, cpm + 0x7c);
+	writel(0x4000000f, cpm + 0x80);
+	writel(0x4000000f, cpm + 0xa8);
+	writel(0x4000000f, cpm + 0xac);
+	writel(0x00000001, cpm + 0xb0);
+	writel(0x0000000f, cpm + 0xbc);
+
+	/* USB PHY register file exactly as stock U-Boot leaves it;
+	 * the kernel inno-PHY driver does its own POR bring-up on top. */
+	writel(0x00ff0080, cpm + CPM_USBVBFIL);
+	writel(0x8a800090, cpm + CPM_USBPCR1);
+	writel(0x00000004, cpm + CPM_USBRDT);
+	writel(0x409919b8, cpm + CPM_USBPCR);
+}
+#endif
+
 int board_init(void)
 {
+#ifdef CONFIG_T41_VENDOR_PAD_INIT
+	/*
+	 * Stock U-Boot never brings the USB PHY up (OPCR SPENDN0 stays
+	 * 0 until Linux); it only leaves the register file preset.
+	 * Mimic that instead of running the A1-derived PHY bring-up.
+	 */
+	t41_vendor_cpm_state();
+#else
 #if defined(CONFIG_USB) || defined(CONFIG_USB_GADGET)
 	t41_usb_phy_init();
 #endif
+#endif
+	return 0;
+}
+
+#ifdef CONFIG_T41_VENDOR_PAD_INIT
+/*
+ * Re-apply the vendor CPM state after all of U-Boot proper's own
+ * driver probing: the DM clk/mmc path re-dirties MSC0CDR (stale
+ * CE + divider) after board_init(), and Linux inherits whatever is
+ * left here. board_late_init() is the last hook before autoboot;
+ * the boot command itself (sf read + bootm) touches no clocks.
+ */
+int board_late_init(void)
+{
+	t41_vendor_cpm_state();
 	return 0;
 }
+#endif
 
