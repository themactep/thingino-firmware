--- a/scripts/Makefile.headersinst
+++ b/scripts/Makefile.headersinst
@@ -71,8 +71,15 @@
 
 quiet_cmd_install = INSTALL $(printdir) ($(words $(all-files))\
                             file$(if $(word 2, $(all-files)),s))
+# Input file list can be very long with deep output paths, use
+# basenames with xargs to avoid "Argument list too long" error.
       cmd_install = \
-        $(CONFIG_SHELL) $< $(installdir) $(input-files); \
+        ( for f in $(header-y); do \
+            if [ -f "$(srcdir)/$$f" ]; then echo "$(srcdir)/$$f"; \
+            elif [ -f "$(oldsrcdir)/$$f" ]; then echo "$(oldsrcdir)/$$f"; fi; \
+          done; \
+          for f in $(genhdr-y); do echo "$(gendir)/$$f"; done \
+        ) | xargs $(CONFIG_SHELL) $< $(installdir); \
         for F in $(wrapper-files); do                                   \
                 echo "\#include <asm-generic/$$F>" > $(installdir)/$$F;    \
         done;                                                           \
