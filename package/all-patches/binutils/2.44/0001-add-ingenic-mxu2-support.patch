From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Ingenic Semiconductor <support@ingenic.com>
Subject: [PATCH] mips: add Ingenic MXU2 128-bit SIMD instruction support

Add assembler, disassembler and opcode support for the Ingenic MXU2
128-bit SIMD extension found on XBurst1 (T20/T21/T23/T31) and
XBurst2 (T40/T41) processors. MXU2 uses COP2 registers ($vr0-$vr31)
for 128-bit vector operations.

New assembler option: -mmxu2 / -mno-mxu2
New disassembler option: -M mxu2

364 instructions covering integer arithmetic, comparisons, shifts,
bitwise ops, float point, dot product, element permute, type
conversions, fixed-point multiply, and load/store operations.

Branch instructions (bnez/beqz variants) use 10-bit PC-relative
offset at bit position 6 with 2-bit right shift.

Ported from Ingenic's GCC 7.2 toolchain (binutils 2017.11) to
binutils 2.44.
---
--- a/include/opcode/mips.h
+++ b/include/opcode/mips.h
@@ -233,7 +233,13 @@
   OP_REG_MSA,
 
   /* MSA control registers $0-$31.  */
-  OP_REG_MSA_CTRL
+  OP_REG_MSA_CTRL,
+
+  /* Ingenic MXU2 vector registers $vr0-$vr31 (128-bit).  */
+  OP_REG_MXU128,
+
+  /* Ingenic MXU2 control registers.  */
+  OP_REG_MXU128_CR
 };
 
 /* Base class for all operands.  */
@@ -1065,6 +1071,8 @@
 /* The Enhanced VA Scheme (EVA) extension has instructions which are
    only valid for the R6 ISA.  */
 #define ASE_EVA_R6		0x02000000
+/* Ingenic MXU2 128-bit SIMD (XBurst1/XBurst2 COP2).  */
+#define ASE_MXU128		0x04000000
 
 /* MIPS ISA defines, use instead of hardcoding ISA level.  */
 
--- a/opcodes/mips-opc.c
+++ b/opcodes/mips-opc.c
@@ -211,6 +211,25 @@
     case 'x': REG (0, 0, GP);
     case 'y': REG (5, 16, CONTROL);
     case 'z': MAPPED_REG (0, 0, GP, reg_0_map);
+
+    case '=':
+      switch (p[1])
+	{
+	case 'h':  REG (5, 6,  MXU128);
+	case 'j':  REG (5, 11, MXU128);
+	case 'k':  SINT (15, 11);
+	case 'l':  SINT (10, 11);
+	case 'n':  UINT (6, 16);
+	case 's':  REG (5, 16, MXU128);
+	case 't':  REG (5, 21, MXU128);
+	case 'v':  SPECIAL (5, 16, IMM_INDEX);
+	case 'w':  SPECIAL (8, 16, IMM_INDEX);
+	case 'x':  REG (5, 6,  MXU128_CR);
+	case 'y':  UINT (8, 16);
+	case 'g':  BRANCH (10, 6, 2);
+	case 'L':  INT_ADJ (10, 11, 0x1ff, 4, false);
+	}
+      break;
     }
   return 0;
 }
@@ -429,6 +448,9 @@
 /* Loongson EXTensions R2 (EXT2) instructions support.  */
 #define LEXT2	ASE_LOONGSON_EXT2
 
+/* Ingenic MXU2 128-bit SIMD (XBurst1/XBurst2 COP2).  */
