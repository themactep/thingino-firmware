+#else
+
+#define LISTENER_HAS_TLS(l) (0)
+#define CONTEXT_HAS_TLS(c)  (0)
+
+#endif /* WITH_TLS_MBEDTLS */
+
+#endif /* NET_MBEDTLS_BROKER_H */
