From aaa6b593863157a70767cd1552c11a819d666d0d Mon Sep 17 00:00:00 2001
From: Paul Philippov <paul@themactep.com>
Date: Sun, 8 Mar 2026 21:19:06 -0400
Subject: [PATCH 1/3] Add ONVIF backchannel Require header support

ServerMediaSubsession gains setRequireTag()/requireTag() - when set,
the subsession's SDP lines are only included in generateSDPDescription()
if the DESCRIBE request contains the matching Require: header value.

RTSPServer::handleCmd_DESCRIBE_afterLookup() now parses the Require:
header and passes it to generateSDPDescription().

This enables ONVIF Streaming Spec Section 5.3 compliance: backchannel
audio tracks are part of the main stream SDP but only appear when the
client sends 'Require: www.onvif.org/ver20/backchannel'.
---
 liveMedia/RTSPServer.cpp                | 15 ++++++++++++++-
 liveMedia/ServerMediaSession.cpp        | 22 +++++++++++++++++++++-
 liveMedia/include/ServerMediaSession.hh |  8 ++++++++
 3 files changed, 43 insertions(+), 2 deletions(-)

diff --git a/liveMedia/RTSPServer.cpp b/liveMedia/RTSPServer.cpp
index d8bdef2..62e5c40 100644
--- a/liveMedia/RTSPServer.cpp
+++ b/liveMedia/RTSPServer.cpp
@@ -24,6 +24,9 @@ along with this library; if not, write to the Free Software Foundation, Inc.,
 #include "Base64.hh"
 #include <GroupsockHelper.hh>
 
+// Forward declaration (defined later in this file)
+static void lookForHeader(char const* headerName, char const* source, unsigned sourceLen, char* resultStr, unsigned resultMaxSize);
+
 ////////// RTSPServer implementation //////////
 
 RTSPServer*
@@ -413,8 +416,18 @@ void RTSPServer::RTSPClientConnection
     // while we're using it:
     session->incrementReferenceCount();
 
+    // Parse the "Require:" header from the original request (if any).
+    // This is used for ONVIF backchannel support: subsessions tagged with a
+    // require tag are only included in the SDP when the client sends the
+    // matching Require: header.
+    char requireHeader[256];
+    requireHeader[0] = '\0';
+    lookForHeader("Require", (char const*)fRequestBuffer, fRequestBytesAlreadySeen,
+		  requireHeader, sizeof requireHeader);
+
     // Then, assemble a SDP description for this session:
-    sdpDescription = session->generateSDPDescription(fAddressFamily);
+    sdpDescription = session->generateSDPDescription(fAddressFamily,
+						       requireHeader[0] != '\0' ? requireHeader : NULL);
     if (sdpDescription == NULL) {
       // This usually means that a file name that was specified for a
       // "ServerMediaSubsession" does not exist.
