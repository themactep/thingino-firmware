   delete[] (char*)fTrackId;
+  delete[] fRequireTag;
   Medium::close(fNext);
 }
 
+void ServerMediaSubsession::setRequireTag(char const* tag) {
+  delete[] fRequireTag;
+  fRequireTag = tag ? strDup(tag) : NULL;
+}
+
 char const* ServerMediaSubsession::trackId() {
   if (fTrackNumber == 0) return NULL; // not yet in a ServerMediaSession
 
