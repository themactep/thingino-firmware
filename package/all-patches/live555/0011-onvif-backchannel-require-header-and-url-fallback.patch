       // returns a string to be delete[]d
 
+  // ONVIF backchannel support: subsessions can declare a "Require" tag.
+  // When set, the subsession's SDP lines are only included if the DESCRIBE
+  // request contains a matching "Require:" header value.
+  void setRequireTag(char const* tag);
+  char const* requireTag() const { return fRequireTag; }
+
   ServerMediaSession* fParentSession;
   u_int32_t fSRTP_ROC; // horrible hack for SRTP; when the ROC changes, regenerate the SDP
 
@@ -196,6 +203,7 @@ private:
 
   unsigned fTrackNumber; // within an enclosing ServerMediaSession
   char const* fTrackId;
+  char* fRequireTag; // if non-NULL, subsession requires this tag in Require: header
 };
 
 #endif
