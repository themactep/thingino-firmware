From f83ecbe94583202cdebdf0f31ffc5f6ff93a84d6 Mon Sep 17 00:00:00 2001
From: Paul Philippov <paul@themactep.com>
Date: Sun, 8 Mar 2026 22:07:45 -0400
Subject: [PATCH 3/3] Fix PLAY/TEARDOWN 404 when client omits stream prefix

Same issue as SETUP: AgentDVR sends PLAY rtsp://host/track4 instead
of PLAY rtsp://host/ch0/track4. Add fallback in handleCmd_withinSession
to try urlSuffix as a track id within the established session when
urlPreSuffix is empty and no other URL pattern matches.
---
 liveMedia/RTSPServer.cpp | 16 ++++++++++++++++
 1 file changed, 16 insertions(+)

diff --git a/liveMedia/RTSPServer.cpp b/liveMedia/RTSPServer.cpp
index 721e671..c83ddb2 100644
--- a/liveMedia/RTSPServer.cpp
+++ b/liveMedia/RTSPServer.cpp
@@ -1753,6 +1753,22 @@ void RTSPServer::RTSPClientSession
       ourClientConnection->handleCmd_notFound();
       return;
     }
+  } else if (urlPreSuffix[0] == '\0' && urlSuffix[0] != '\0') {
+    // Fallback: client sent a bare track URL (e.g. PLAY rtsp://host/track4)
+    // without the stream prefix. Try urlSuffix as a track id in our session.
+    ServerMediaSubsessionIterator iter(*fOurServerMediaSession);
+    subsession = NULL;
+    ServerMediaSubsession* sub;
+    while ((sub = iter.next()) != NULL) {
+      if (sub->trackId() != NULL && strcmp(sub->trackId(), urlSuffix) == 0) {
+	subsession = sub;
+	break;
+      }
+    }
+    if (subsession == NULL) {
+      ourClientConnection->handleCmd_notFound();
+      return;
+    }
   } else { // the request doesn't match a known stream and/or track at all!
     ourClientConnection->handleCmd_notFound();
     return;
-- 
