From 0000000000000000000000000000000000000001 Mon Sep 17 00:00:00 2001
From: Thingino Project <thingino@thingino.com>
Date: Mon, 03 Mar 2026 00:00:00 +0000
Subject: [PATCH] Fix GCC 15 + glibc _Generic macro conflicts

With GCC 15, the gnulib-generated headers include ISO C N3322 declaration
blocks that redeclare bsearch, qsort, and wmemchr as functions.  However,
glibc defines these as _Generic macros, which get expanded when gnulib tries
to declare them, causing parse errors:

  error: expected identifier or '(' before '_Generic'

Fix by undefining the glibc macros before the gnulib function declarations.

--- a/lib/stdlib.in.h
+++ b/lib/stdlib.in.h
@@ -224,6 +224,8 @@
 
 /* Declarations for ISO C N3322.  */
 #if defined __GNUC__ && __GNUC__ >= 15 && !defined __clang__
+# undef bsearch
+# undef qsort
 _GL_EXTERN_C void *bsearch (const void *__key,
                             const void *__base, size_t __nmemb, size_t __size,
                             int (*__compare) (const void *, const void *))
--- a/lib/wchar.in.h
+++ b/lib/wchar.in.h
@@ -300,6 +300,7 @@
 # endif
   _GL_ATTRIBUTE_NONNULL_IF_NONZERO (1, 3)
   _GL_ATTRIBUTE_NONNULL_IF_NONZERO (2, 3);
+# undef wmemchr
 # ifndef __cplusplus
 _GL_EXTERN_C wchar_t *wmemchr (const wchar_t *__s, wchar_t __wc, size_t __n)
   _GL_ATTRIBUTE_NONNULL_IF_NONZERO (1, 3);
