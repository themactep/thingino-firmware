config BR2_PACKAGE_MAGIK_MODELS
	bool "magik-models"
	depends on BR2_PACKAGE_INGENIC_LIB_IVS
	help
	  Pre-trained JZDL neural network models for Ingenic SoCs.

if BR2_PACKAGE_MAGIK_MODELS

config BR2_PACKAGE_MAGIK_MODELS_YOLOV5
	bool "YOLOv5 (person/bicycle/car/motorcycle — 870KB)"
	default y
	help
	  4-class object detection model.

config BR2_PACKAGE_MAGIK_MODELS_PERSONDET
	bool "Person detection (898KB)"
	help
	  Single-class person detection model.

config BR2_PACKAGE_MAGIK_MODELS_FACEDET
	bool "Face detection (258KB)"
	help
	  Face detection model.

endif
