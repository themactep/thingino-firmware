#!/bin/sh

# wolfSSL Certificate Generator for Thingino
# This script generates SSL certificates using wolfSSL tools and libraries
# Usage: wolfssl-certgen -h hostname -c cert_file -k key_file [-d days]

HOSTNAME=""
CERT_FILE=""
KEY_FILE=""
DAYS=3650  # 10 years default
KEY_SIZE=256  # 256-bit ECDSA (fast and secure for embedded devices)

# Parse command line arguments
while [ $# -gt 0 ]; do
    case "$1" in
        -h|--hostname)
            HOSTNAME="$2"
            shift 2
            ;;
        -c|--cert)
            CERT_FILE="$2"
            shift 2
            ;;
        -k|--key)
            KEY_FILE="$2"
            shift 2
            ;;
        -d|--days)
            DAYS="$2"
            shift 2
            ;;
        -s|--key-size)
            KEY_SIZE="$2"
            shift 2
            ;;
        --help)
            echo "Usage: $0 -h hostname -c cert_file -k key_file [-d days] [-s key_size]"
            echo "  -h, --hostname   Hostname for certificate CN"
            echo "  -c, --cert       Output certificate file"
            echo "  -k, --key        Output private key file"
            echo "  -d, --days       Certificate validity in days (default: 3650)"
            echo "  -s, --key-size   ECDSA key size in bits (default: 256)"
            echo "                   Supported: 224, 256, 384, 521"
            exit 0
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Validate required parameters
if [ -z "$HOSTNAME" ] || [ -z "$CERT_FILE" ] || [ -z "$KEY_FILE" ]; then
    echo "Error: Missing required parameters"
    echo "Usage: $0 -h hostname -c cert_file -k key_file [-d days] [-s key_size]"
    exit 1
fi

# Create directories if they don't exist
mkdir -p "$(dirname "$CERT_FILE")" "$(dirname "$KEY_FILE")"

# Function to generate certificate using wolfSSL C API
generate_with_wolfssl_api() {
    # This would require a compiled C program using wolfSSL's certificate generation API
    # For now, we'll use a placeholder that could be implemented later
    return 1
}



# Function to generate certificate using OpenSSL compatibility layer
generate_with_openssl_compat() {
    if command -v openssl >/dev/null 2>&1; then
        echo "Generating certificate using OpenSSL compatibility layer..."

        # Generate private key
        if openssl genrsa -out "$KEY_FILE" 2048 2>/dev/null; then
            # Generate self-signed certificate
            if openssl req -new -x509 -key "$KEY_FILE" -out "$CERT_FILE" \
                -days "$DAYS" -subj "/C=US/O=Thingino/CN=$HOSTNAME" 2>/dev/null; then
                echo "Certificate generated successfully"
                return 0
            fi
        fi
    fi
    return 1
}

# Function to generate certificate using wolfCLU
generate_with_wolfclu() {
    if command -v wolfssl >/dev/null 2>&1; then
        echo "Generating certificate using wolfCLU..."
        
        # Generate private key
        if wolfssl genkey rsa -size 2048 -out "$KEY_FILE" 2>/dev/null; then
            # Generate self-signed certificate
            if wolfssl req -new -x509 -key "$KEY_FILE" -out "$CERT_FILE" \
                -days "$DAYS" -subj "/C=US/O=Thingino/CN=$HOSTNAME" 2>/dev/null; then
                echo "Certificate generated successfully"
                return 0
            fi
        fi
    fi
    return 1
}

# Try different methods in order of preference
echo "Generating SSL certificate for hostname: $HOSTNAME"

# Method 1: Native wolfSSL certificate generator (if available)
if [ -x /usr/bin/wolfssl-certgen-native ]; then
    echo "Trying native wolfSSL certificate generator..."
    if /usr/bin/wolfssl-certgen-native -h "$HOSTNAME" -c "$CERT_FILE" -k "$KEY_FILE" -d "$DAYS" -s "$KEY_SIZE" 2>/dev/null; then
        echo "Certificate generated with native wolfSSL"
        exit 0
    else
        echo "Native wolfSSL certificate generator failed (wolfSSL not compiled with --enable-certgen)"
    fi
fi

# Method 2: wolfCLU (if available)
if command -v wolfssl >/dev/null 2>&1; then
    echo "Trying wolfCLU certificate generator..."
    if generate_with_wolfclu; then
        exit 0
    fi
fi

# Method 3: OpenSSL compatibility layer (if available)
if command -v openssl >/dev/null 2>&1; then
    echo "Trying OpenSSL compatibility layer..."
    if generate_with_openssl_compat; then
        exit 0
    fi
fi

# No working certificate generation methods available
echo "ERROR: No working certificate generation methods available"
echo "Available options:"
echo "  - Rebuild firmware with wolfSSL certificate generation support"
echo "  - Use HTTP-only mode (uhttpd will fall back automatically)"
echo ""
echo "Certificate generation requires:"
echo "  - wolfSSL compiled with --enable-certgen --enable-keygen --enable-ecc"
echo "  - OR wolfCLU tools"
echo "  - OR OpenSSL compatibility layer"
echo ""
echo "For now, access the web interface via: http://$HOSTNAME/"

exit 1
