#!/bin/sh

# Script to control the DW9714 VCM focus using BusyBox i2c commands
# Takes an argument from 0 to 100 to set the focus position percentage

if [ "$#" -ne 1 ]; then
	echo "Usage: $0 <focus_percentage>
Where:
	<focus_percentage> should be an integer from 0 to 100
" >&2
	exit 1
fi

FOCUS_PERCENTAGE=$1

# Validate input
if [ "$FOCUS_PERCENTAGE" -lt 0 ] || [ "$FOCUS_PERCENTAGE" -gt 100 ]; then
	echo "Error: focus_percentage must be between 0 and 100."
	exit 1
fi

bool_is_true() {
	local value
	value=$(printf '%s' "$1" | tr 'A-Z' 'a-z')
	case "$value" in
		1 | true | yes | on)
			return 0
			;;
	esac
	return 1
}

# get gpio

MOTORS_CONFIG_JSON=/etc/thingino.json

# Case object : { "pin": 42, ...}
if pin=$(jct "$MOTORS_CONFIG_JSON" get "motors.gpio_focus.pin" 2>/dev/null); then
	if ! active_low=$(jct "$MOTORS_CONFIG_JSON" get "motors.gpio_focus.active_low" 2>/dev/null); then
		active_low="false"
	fi
	case "$active_low" in
		true | false) ;;
		*)
			echo "Error: invalid active_low value '$active_low'" >&2
			exit 1
			;;
	esac
# Case direct value
else
	pin=$(jct "$MOTORS_CONFIG_JSON" get "motors.gpio_focus" 2>/dev/null) || {
		echo "Error: motors.gpio_focus not found" >&2
		exit 1
	}
	active_low="false"
fi

if [ "$pin" = "-1" ]; then
	echo "Error: pin is undefined" >&2
	exit 1
fi

state=1
if bool_is_true "$active_low"; then
	state=0
fi
echo "## pin=$pin active_low=$active_low state=$state"

# bring up gpio if needed

if [ "$(gpio info $pin | grep DIR | cut -d' ' -f2)" != "out" ]; then
	echo "## bringing gpio up"
	gpio set $pin $state
else
	echo "## gpio already up"
fi

# and set focus

# Convert percentage to DAC value (0-511)
DAC_VALUE=$((FOCUS_PERCENTAGE * 511 / 100))

# Construct the 16-bit value to send to the DAC
HIGH_BYTE=$(((DAC_VALUE >> 4) & 0xFF))
LOW_BYTE=$(((DAC_VALUE << 4) & 0xF0))

# Send the value using i2cset (assumes I2C bus 0 and address 0x0c)
i2cset -y 0 0x0c $HIGH_BYTE $LOW_BYTE i

echo "Focus set to $FOCUS_PERCENTAGE% (DAC value: $DAC_VALUE)"

exit 0
