#!/bin/sh

PATH=/bin:/sbin:/usr/bin:/usr/sbin${PATH:+:$PATH}
export PATH

DAEMON="/usr/bin/prudynt"
PIDFILE="/run/prudynt.pid"
HEARTBEAT_INIT="/etc/init.d/S99heartbeat"

restart_heartbeat() {
	if [ -x "$HEARTBEAT_INIT" ]; then
		"$HEARTBEAT_INIT" restart >/dev/null 2>&1
	fi
}

stop_heartbeat() {
	if [ -x "$HEARTBEAT_INIT" ]; then
		"$HEARTBEAT_INIT" stop >/dev/null 2>&1
	fi
}

start_daemon() {
	start-stop-daemon -S -b -m -p "$PIDFILE" -x "$DAEMON"
}

stop_daemon() {
	if [ -f "$PIDFILE" ]; then
		start-stop-daemon -K -p "$PIDFILE" -x "$DAEMON"
		status=$?
		rm -f "$PIDFILE"
		return $status
	fi

	start-stop-daemon -K -x "$DAEMON"
}

start() {
	echo -c 15 "Starting Prudynt"
	start_daemon
	status=$?
	if [ "$status" -eq 0 ]; then
		restart_heartbeat
	fi
	return "$status"
}

stop() {
	echo -c 15 "Stopping Prudynt"
	stop_heartbeat
	stop_daemon
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		stop || true
		sleep 1
		start
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
		;;
esac

exit 0
