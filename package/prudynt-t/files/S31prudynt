#!/bin/sh

DAEMON="prudynt"
DAEMON_PATH="/usr/bin/$DAEMON"
PIDFILE="/run/$DAEMON.pid"

start() {
	printf "Starting %s: " "$DAEMON"
	start-stop-daemon -S -q -b -m -p "$PIDFILE" -x "$DAEMON_PATH"
	rc=$?
	[ $rc = 0 ] && echo "OK" || echo "FAIL"
	return $rc
}

stop() {
	printf "Stopping %s: " "$DAEMON"
	start-stop-daemon -K -q -p "$PIDFILE" -x "$DAEMON_PATH"
	rc=$?
	if [ $rc != 0 ] && pidof "$DAEMON" >/dev/null 2>&1; then
		start-stop-daemon -K -q -x "$DAEMON_PATH"
		rc=$?
	fi
	[ $rc = 0 ] && echo "OK" || echo "FAIL"
	rm -f "$PIDFILE"
	return $rc
}

restart() {
	stop
	sleep 1
	start
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart|reload)
		restart
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
		;;
esac

exit $?
