#!/bin/sh

set_mic_enabled() {
	value="$1"
	printf '{"audio":{"mic_enabled":%s},"action":{"restart_thread":4}}\n' "$value" | prudyntctl json - >/dev/null 2>&1
}

get_mic_enabled() {
	jct /etc/prudynt.json get "audio.mic_enabled"
}

case "$1" in
	on)
		set_mic_enabled "true" || exit 1
		;;
	off)
		set_mic_enabled "false" || exit 1
		;;
	toggle)
		if [ "$(get_mic_enabled)" = "true" ]; then
			set_mic_enabled "false" || exit 1
		else
			set_mic_enabled "true" || exit 1
		fi
		;;
	status)
		get_mic_enabled
		;;
	*)
		echo "Usage: $0 {on|off|toggle|status}" >&2
		exit 1
		;;
esac

exit 0
