#!/bin/env sh
# Sends data to a Gotify server
# https://gotify.net/docs/msg

. /usr/share/prudynt-helpers
. /usr/share/send2common

domain="gotify"
config_file="/etc/send2.json"

show_help() {
	echo "Usage: $0 [options]
Where:
	-u url       Gotify server base URL (e.g. http://gotify.local)
	-t token     Application token
	-n title     Message title
	-m message   Message body
	-e json      Extras JSON object
	-z N         Priority (0-10)
	-v           Verbose output
" >&2
	exit 0
}

json_escape() {
	printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e 's/\r//g' -e ':a;N;$!ba;s/\n/\\n/g'
}

read_config() {
	[ -f "$config_file" ] || return

	message=$(get_value message)
	priority=$(get_value priority)
	title=$(get_value title)
	token=$(get_value token)
	url=$(get_value url)
	extras=$(get_value extras)
}

read_config

while getopts e:m:n:t:u:vz: flag; do
	case "$flag" in
		e) extras=$OPTARG ;;
		m) message=$OPTARG ;;
		n) title=$OPTARG ;;
		t) token=$OPTARG ;;
		u) url=$OPTARG ;;
		v) verbose="true" ;;
		z) priority=$OPTARG ;;
		*) show_help ;;
	esac
done

if [ -z "$url" ]; then
	echo_error "Gotify URL is not set"
	exit 1
fi

if [ -z "$token" ]; then
	echo_error "Gotify token is not set"
	exit 1
fi

[ -z "$title" ] && title="Thingino Camera"
[ -z "$message" ] && message="Motion detected at %Y-%m-%d %H:%M:%S"
[ -z "$priority" ] && priority=5
message=$(date +"$message")
if [ "true" = "$verbose" ]; then
	curl_verbosity="--verbose"
else
	curl_verbosity="--silent"
fi

endpoint="${url%/}/message?token=$token"

payload_file=$(mktemp)
add_to_garbage "$payload_file"

{
	printf '{\n'
	printf '  "title": "%s",\n' "$(json_escape "$title")"
	printf '  "message": "%s",\n' "$(json_escape "$message")"
	printf '  "priority": %s' "$priority"
	if [ -n "$extras" ] && [ "$extras" != "null" ]; then
		printf ',\n  "extras": %s' "$extras"
	fi
	printf '\n}\n'
} > "$payload_file"

if [ "true" = "$verbose" ]; then
	debug_command="curl --request POST --url \"$endpoint\" --header 'Content-Type: application/json' --data-binary @$payload_file"
	echo_command "$debug_command"
fi

if ! curl --show-error --fail --connect-timeout 10 --max-time 30 --retry 3 --location --max-redirs 5 \
		$curl_verbosity \
		--url "$endpoint" \
		--header 'Content-Type: application/json' \
		--data-binary "@$payload_file" >/dev/null; then
	echo_error "Failed to send Gotify message"
	exit 1
fi

exit 0
