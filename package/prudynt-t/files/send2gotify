#!/bin/env sh
# Sends data to a Gotify server
# https://gotify.net/docs/msg

. /usr/share/prudynt-helpers
. /usr/share/send2common

domain="gotify"
config_file="/etc/send2.json"

show_help() {
	echo "Usage: $0 [options]
Where:
	-u url       Gotify server base URL (e.g. http://gotify.local)
	-t token     Application token
	-n title     Message title
	-m message   Message body
	-z N         Priority (0-10)
	-f file      Attach file
	-S           Send photo
	-V           Send video
	-v           Verbose output
" >&2
	exit 0
}

read_config() {
	[ -f "$config_file" ] || return

	message=$(get_value message)
	priority=$(get_value priority)
	title=$(get_value title)
	token=$(get_value token)
	url=$(get_value url)
}

read_config

while getopts f:m:n:t:u:vz:SV flag; do
	case "$flag" in
		f) file=$OPTARG; send_photo="false"; send_video="false" ;;
		m) message=$OPTARG ;;
		n) title=$OPTARG ;;
		t) token=$OPTARG ;;
		u) url=$OPTARG ;;
		v) verbose="true" ;;
		z) priority=$OPTARG ;;
		S) send_photo="true" ;;
		V) send_video="true" ;;
		*) show_help ;;
	esac
done

# use config settings only if not set from command line
if [ -z "$file" ] && [ "true" != "$send_photo" ] && [ "true" != "$send_video" ]; then
	send_photo=$(get_value send_photo)
	send_video=$(get_value send_video)
fi

if [ -z "$url" ]; then
	echo_error "Gotify URL is not set"
	exit 1
fi

if [ -z "$token" ]; then
	echo_error "Gotify token is not set"
	exit 1
fi

[ -z "$title" ] && title="Thingino Camera"
[ -z "$message" ] && message="Motion detected at %Y-%m-%d %H:%M:%S"
[ -z "$priority" ] && priority=5
message=$(date +"$message")
if [ "true" = "$verbose" ]; then
	curl_verbosity="--verbose"
else
	curl_verbosity="--silent"
fi

endpoint="${url%/}/message?token=$token"

# Gotify supports file attachment via multipart form-data.
# We send one attachment with precedence: file > snapshot > video.
attachment=""
if [ -n "$file" ] && [ -f "$file" ]; then
	attachment="$file"
elif [ "true" = "$send_photo" ]; then
	attachment=$(copy_photo)
elif [ "true" = "$send_video" ]; then
	attachment=$(copy_video)
fi

if [ "true" = "$verbose" ]; then
	if [ -n "$attachment" ]; then
		echo_command "curl --request POST --url \"$endpoint\" --form \"title=$title\" --form \"message=$message\" --form \"priority=$priority\" --form \"file=@$attachment\""
	else
		echo_command "curl --request POST --url \"$endpoint\" --form \"title=$title\" --form \"message=$message\" --form \"priority=$priority\""
	fi
fi

if [ -n "$attachment" ]; then
	if ! curl --show-error --fail --connect-timeout 10 --max-time 30 --retry 3 --location --max-redirs 5 \
		$curl_verbosity \
		--request POST \
		--url "$endpoint" \
		--form "title=$title" \
		--form "message=$message" \
		--form "priority=$priority" \
		--form "file=@$attachment" >/dev/null; then
		echo_error "Failed to send Gotify message"
		exit 1
	fi
else
	if ! curl --show-error --fail --connect-timeout 10 --max-time 30 --retry 3 --location --max-redirs 5 \
		$curl_verbosity \
		--request POST \
		--url "$endpoint" \
		--form "title=$title" \
		--form "message=$message" \
		--form "priority=$priority" >/dev/null; then
		echo_error "Failed to send Gotify message"
		exit 1
	fi
fi

exit 0
