/* generated from configs for 360_d619_t10_ov9732_rtl8188eu */
/ {
	leds {
		compatible = "gpio-leds";
		led_b {
			label = "thingino:led_b";
			gpios = <&{/soc/pinctrl@0x10010000/gpc} 8 1 0>;
			default-state = "off";
		};
		led_r {
			label = "thingino:led_r";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 17 0 0>;
			default-state = "off";
		};
	};
};
