/* generated from configs for wyze_cam3pro_t40xp_gc4653_rtl8192fs */
/ {
	leds {
		compatible = "gpio-leds";
		led_b {
			label = "thingino:led_b";
			gpios = <&{/soc/pinctrl@0x10010000/gpd} 9 1 0>;
			default-state = "off";
		};
		led_y {
			label = "thingino:led_y";
			gpios = <&{/soc/pinctrl@0x10010000/gpd} 10 1 0>;
			default-state = "off";
		};
	};
};
