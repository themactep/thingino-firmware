BR2_PACKAGE_SELECT_STRACE=y
BR2_THINGINO_AUDIO=y
BR2_SENSOR_GC2053=y
BR2_SENSOR_PARAMS="sensor_max_fps=30 data_interface=1"
BR2_THINGINO_DEV_PACKAGES=y
BR2_THINGINO_AUDIO_DMIC=y
BR2_THINGINO_BUTTON=y
BR2_THINGINO_PWM_ENABLE=y
BR2_THINGINO_SDCARD=y
