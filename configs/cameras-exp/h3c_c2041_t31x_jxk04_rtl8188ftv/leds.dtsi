/* generated from configs for h3c_c2041_t31x_jxk04_rtl8188ftv */
/ {
	leds {
		compatible = "gpio-leds";
		led_b {
			label = "thingino:led_b";
			gpios = <&{/soc/pinctrl@0x10010000/gpa} 16 1 0>;
			default-state = "off";
		};
		led_r {
			label = "thingino:led_r";
			gpios = <&{/soc/pinctrl@0x10010000/gpa} 17 1 0>;
			default-state = "off";
		};
	};
};
