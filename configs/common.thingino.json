{
  "admin_name": "Thingino Admin",
  "enable_updates": true,
  "led": {
    "startup_indicator": "off"
  },
  "rsyslog": {
    "host": "",
    "local": false,
    "port": 514
  },
  "usb_console": false,
  "watchdog": {
    "device": "/dev/watchdog",
    "disable": false,
    "timeout": 60
  },
  "webui": {
    "level": "user",
    "paranoid": false,
    "theme": "dark"
  },
  "wireguard": {
    "enabled": false
  },
  "motors": {
    "motion_driver": "legacy",
    "gpio_focus": -1,
    "gpio_invert": false,
    "gpio_pan": "",
    "gpio_switch": false,
    "gpio_tilt": "",
    "homing": true,
    "pos_0": "2000,1000",
    "speed_pan": 900,
    "speed_tilt": 900,
    "accel_pan": 0,
    "accel_tilt": 0,
    "steps_pan": 4000,
    "steps_tilt": 2000
  }
}
