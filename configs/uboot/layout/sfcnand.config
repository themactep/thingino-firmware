# SPI-NAND U-Boot environment layout.
#
# Selected instead of sfcnor.config when BR2_THINGINO_FLASH_NAND=y (see
# thingino.mk). NOR stores the env at a raw CONFIG_ENV_OFFSET; NAND stores it in
# the UBI volume "uboot-env" inside the "ubi" MTD partition, matching the fork's
# isvp_*_sfcnand_defconfig. Selecting this fragment instead of sfcnor.config
# guarantees the NOR raw-offset env settings are never applied to a NAND build.
#
# Flash layout the rest of thingino must honour (from t40-isvp-nand.dtsi):
#   0x000000..0x100000  boot : SPL @ 0 + U-Boot @ 0x8000 (raw)
#   0x100000..end       ubi  : UBI volumes uboot-env / kernel / rootfs / overlay
CONFIG_ENV_IS_IN_UBI=y
CONFIG_ENV_UBI_PART="ubi"
CONFIG_ENV_UBI_VOLUME="uboot-env"
CONFIG_ENV_SIZE=0x10000
CONFIG_ENV_SECT_SIZE=0x10000
# Ensure the NOR backend cannot also be selected.
# CONFIG_ENV_IS_IN_SPI_FLASH is not set
