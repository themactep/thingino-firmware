# SPI-NAND U-Boot environment layout.
#
# Selected (instead of sfcnor.config) when BR2_THINGINO_FLASH_NAND=y.
#
# Unlike NOR — where the env is a raw region at CONFIG_ENV_OFFSET — NAND stores
# the environment in a UBI volume ("uboot-env") inside the "ubi" MTD partition.
# This mirrors the isvp_*_sfcnand_defconfig and, by replacing sfcnor.config,
# guarantees the NOR raw-offset env settings are never applied to a NAND build.
#
# Flash layout the rest of thingino must honour:
#   0x000000..0x100000  SPL + U-Boot proper (raw, bad-block managed by SPL)
#   0x100000..end       "ubi" MTD partition: volumes uboot-env / kernel / rootfs
CONFIG_ENV_IS_IN_UBI=y
CONFIG_ENV_UBI_PART="ubi"
CONFIG_ENV_UBI_VOLUME="uboot-env"
CONFIG_ENV_SIZE=0x10000
CONFIG_ENV_SECT_SIZE=0x10000
# Make sure the NOR backend cannot also be selected.
# CONFIG_ENV_IS_IN_SPI_FLASH is not set
