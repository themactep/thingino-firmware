/* generated from configs for wansview_q5_t23n_sc2336_atbm6012bx */
/ {
	leds {
		compatible = "gpio-leds";
		led_b {
			label = "thingino:led_b";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 8 1 0>;
			default-state = "off";
		};
		led_r {
			label = "thingino:led_r";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 14 1 0>;
			default-state = "off";
		};
	};
};
