/* generated from configs for cinnado_d1_t31l_sc2336_atbm6031 */
/ {
	leds {
		compatible = "gpio-leds";
		led_b {
			label = "thingino:led_b";
			gpios = <&{/soc/pinctrl@0x10010000/gpa} 9 0 0>;
			default-state = "off";
		};
		led_r {
			label = "thingino:led_r";
			gpios = <&{/soc/pinctrl@0x10010000/gpa} 8 0 0>;
			default-state = "off";
		};
	};
};
