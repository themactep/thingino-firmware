/* generated from configs for wyze_vdb1_t31x_sc4236_rtl8189ftv */
/ {
	leds {
		compatible = "gpio-leds";
		led_b {
			label = "thingino:led_b";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 7 0 0>;
			default-state = "off";
		};
		led_y {
			label = "thingino:led_y";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 6 0 0>;
			default-state = "off";
		};
	};
};
