/* generated from configs for wyze_campan3_t31x_gc2053_atbm6031 */
/ {
	leds {
		compatible = "gpio-leds";
		led_b {
			label = "thingino:led_b";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 6 0 0>;
			default-state = "off";
		};
		led_r {
			label = "thingino:led_r";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 7 0 0>;
			default-state = "off";
		};
	};
};
