/* generated from configs for dekco_dc5l_t31l_sc3336_rtl8188ftv */
/ {
	leds {
		compatible = "gpio-leds";
		led_b {
			label = "thingino:led_b";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 25 0 0>;
			default-state = "off";
		};
		led_g {
			label = "thingino:led_g";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 26 0 0>;
			default-state = "off";
		};
	};
};
