/* generated from configs for iflytek_xfp301m_t31x_jxq03_rtl8188ftv */
/ {
	leds {
		compatible = "gpio-leds";
		led_g {
			label = "thingino:led_g";
			gpios = <&{/soc/pinctrl@0x10010000/gpa} 16 1 0>;
			default-state = "off";
		};
		led_r {
			label = "thingino:led_r";
			gpios = <&{/soc/pinctrl@0x10010000/gpa} 17 1 0>;
			default-state = "off";
		};
	};
};
