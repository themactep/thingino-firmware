/* generated from configs for iget_c5pt_t41lq_gc4023_jl1101 */
/ {
	leds {
		compatible = "gpio-leds";
		led_b {
			label = "thingino:led_b";
			gpios = <&{/soc/pinctrl@0x10010000/gpc} 15 0 0>;
			default-state = "off";
		};
		led_r {
			label = "thingino:led_r";
			gpios = <&{/soc/pinctrl@0x10010000/gpc} 16 0 0>;
			default-state = "off";
		};
	};
};
