/* generated from configs for xiaomi_sxj02zm_t20l_ps5250_rtl8189ftv */
/ {
	leds {
		compatible = "gpio-leds";
		led_b {
			label = "thingino:led_b";
			gpios = <&{/soc/pinctrl@0x10010000/gpc} 12 1 0>;
			default-state = "off";
		};
		led_y {
			label = "thingino:led_y";
			gpios = <&{/soc/pinctrl@0x10010000/gpc} 11 1 0>;
			default-state = "off";
		};
	};
};
