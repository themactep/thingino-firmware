/* generated from configs for wyze_campan1_t20x_jxf22_rtl8189etv */
/ {
	leds {
		compatible = "gpio-leds";
		led_b {
			label = "thingino:led_b";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 7 1 0>;
			default-state = "off";
		};
		led_y {
			label = "thingino:led_y";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 6 1 0>;
			default-state = "off";
		};
	};
};
