# Kernel config fragment for Wansview A1 (T23ZN / ATBM6461).
#
# CONFIG_LOCALVERSION is left at the Thingino default (__isvp_pike_1.0__).
# The ATBM6461 binary .ko ships pre-patched to match this localversion.

# CONFIG_TRACEPOINTS is not set
#
# Required for atbm6461_wifi_sdio.ko symbol resolution.
#
# warn_slowpath_fmt / warn_slowpath_null are inside #ifdef CONFIG_BUG in
# kernel/panic.c — the .ko calls them so CONFIG_BUG must be y.
CONFIG_BUG=y
#
# print_hex_dump_bytes is inside #if !defined(CONFIG_DYNAMIC_DEBUG) in
# lib/hexdump.c — with DYNAMIC_DEBUG=y the symbol is compiled out.
# CONFIG_DYNAMIC_DEBUG is not set
#
# The ATBM6461 SDIO chip is physically wired to MMC1 (PB8-PB14, GPIO_FUNC_1),
# confirmed by the stock OEM "Immortal" kernel containing the string "msc1-pB"
# and the ATBM6461 binary calling jzmmc_manual_detect(1, on) (index=1 = MMC1).
#
# MMC1 Kconfig options (CONFIG_JZMMC_V12_MMC1, CONFIG_JZMMC_V12_MMC1_PB_4BIT,
# CONFIG_MMC1_MAX_FREQ) are set via WIFI_ATBM6461_LINUX_CONFIG_FIXUPS in
# wifi-atbm6461.mk, not here, because the base T23 generic config has
# CONFIG_JZMMC_V12_MMC1=not set, and fragment settings are overwritten by
# olddefconfig before the FIXUPS hooks run.
#
# CONFIG_TRACEPOINTS is not set — disable for OEM binary .ko ABI compatibility.
# The ATBM6461 binary .ko was compiled against the OEM Ingenic SDK which lacks
# TRACEPOINTS, making struct module 0x118 bytes.  With TRACEPOINTS=y the struct
# grows to 0x120 bytes, causing crashes (module_put reads refptr past end).
#
# Kconfig's "select TRACEPOINTS" (CHIP_T23) would normally force this back to y
# during olddefconfig; WIFI_ATBM6461_LINUX_CONFIG_FIXUPS in wifi-atbm6461.mk
# removes the select line from the build-time Kconfig to prevent that.
