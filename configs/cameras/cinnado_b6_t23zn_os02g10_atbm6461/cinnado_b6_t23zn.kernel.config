# Kernel config fragment for Cinnado B6 (T23ZN / OS02G10 / ATBM6461).
#
# The stock B6 firmware identifies itself as OS02G10_6461_S and embeds
# atbm6461_wifi_sdio.ko. These requirements mirror the Wansview A1 ZRT profile.

# Required for atbm6461_wifi_sdio.ko symbol resolution.
#
# warn_slowpath_fmt / warn_slowpath_null are inside #ifdef CONFIG_BUG in
# kernel/panic.c -- the .ko calls them so CONFIG_BUG must be y.
CONFIG_BUG=y
#
# print_hex_dump_bytes is inside #if !defined(CONFIG_DYNAMIC_DEBUG) in
# lib/hexdump.c -- with DYNAMIC_DEBUG=y the symbol is compiled out.
# CONFIG_DYNAMIC_DEBUG is not set
#
# The stock B6 kernel contains msc1-pB and the ATBM6461 binary calls
# jzmmc_manual_detect(1, on). MMC1 fixups are provided by wifi-atbm6461.mk.
