/* generated from configs for sim_simp400t_t31x_gc4653_eth+ssv6155p */
/ {
	leds {
		compatible = "gpio-leds";
		led_g {
			label = "thingino:led_g";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 26 0 0>;
			default-state = "off";
		};
		led_r {
			label = "thingino:led_r";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 25 0 0>;
			default-state = "off";
		};
	};
};
