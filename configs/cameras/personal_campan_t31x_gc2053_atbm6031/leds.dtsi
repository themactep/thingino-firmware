/* generated from configs for personal_campan_t31x_gc2053_atbm6031 */
/ {
	leds {
		compatible = "gpio-leds";
		led_b {
			label = "thingino:led_b";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 16 0 0>;
			default-state = "off";
		};
		led_y {
			label = "thingino:led_y";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 15 0 0>;
			default-state = "off";
		};
	};
};
