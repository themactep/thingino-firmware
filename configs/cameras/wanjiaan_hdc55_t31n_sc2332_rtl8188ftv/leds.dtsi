/* generated from configs for wanjiaan_hdc55_t31n_sc2332_rtl8188ftv */
/ {
	leds {
		compatible = "gpio-leds";
		led_b {
			label = "thingino:led_b";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 20 0 0>;
			default-state = "off";
		};
		led_r {
			label = "thingino:led_r";
			gpios = <&{/soc/pinctrl@0x10010000/gpb} 21 0 0>;
			default-state = "off";
		};
	};
};
