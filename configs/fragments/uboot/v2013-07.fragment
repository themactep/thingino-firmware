BR2_TARGET_UBOOT_CUSTOM_VERSION=y
BR2_TARGET_UBOOT_CUSTOM_VERSION_VALUE="2013.07"
BR2_TARGET_UBOOT_BUILD_SYSTEM_LEGACY=y
# BR2_TARGET_UBOOT_BUILD_SYSTEM_KCONFIG is not set
# BR2_TARGET_UBOOT_USE_DEFCONFIG is not set
# BR2_TARGET_UBOOT_USE_CUSTOM_CONFIG is not set
# BR2_TARGET_UBOOT_CONFIG_FRAGMENT_FILES is not set
# BR2_TARGET_UBOOT_DEFAULT_ENV_FILE is not set
BR2_TARGET_UBOOT_FORMAT_CUSTOM=y
BR2_TARGET_UBOOT_FORMAT_CUSTOM_NAME="u-boot-lzo-with-spl.bin"
