#!/bin/sh
# LED controller that drives kernel LED channels by color first-letter
# (r, g, b, y, c, m, w, ...).

LED_LETTERS=""
CHANNEL_COUNT=0

show_help() {
	echo "Usage: $0 <color|off>
Colors, use the first letter:
  r - red
  g - green
  b - blue
  y - yellow
  v - violet
  c - cyan
  m - magenta
  w - white
  p - purple
" >&2
	exit 1
}

letter_in_list() {
	case " $LED_LETTERS " in
		*" $1 "*) return 0 ;;
		*) return 1 ;;
	esac
}

register_sysfs_channel() {
	local letter="$1" upper existed=1 sysfs_dir="$2"
	[ -n "$letter" ] || return 1
	[ -d "$sysfs_dir" ] || return 1
	upper=$(printf '%s' "$letter" | tr '[:lower:]' '[:upper:]')
	eval "LED_SYSFS_${upper}='$sysfs_dir'"
	eval "LED_ON_${upper}=1"
	eval "LED_OFF_${upper}=0"
	if ! letter_in_list "$letter"; then
		LED_LETTERS="$LED_LETTERS $letter"
		existed=0
	fi
	[ "$existed" -eq 0 ] && CHANNEL_COUNT=$((CHANNEL_COUNT + 1))
}

discover_from_sysfs() {
	local path name suffix letter
	for path in /sys/class/leds/led_*; do
		[ -d "$path" ] || continue
		name=${path##*/}
		suffix=${name#led_}
		letter=$(printf '%s' "$suffix" | tr '[:upper:]' '[:lower:]' | cut -c1)
		[ -n "$letter" ] || continue
		register_sysfs_channel "$letter" "$path"
	done
}

channel_defined() {
	local letter_u sysfs_dir
	letter_u=$(printf '%s' "$1" | tr '[:lower:]' '[:upper:]')
	eval "sysfs_dir=\${LED_SYSFS_${letter_u}:-}"
	[ -n "$sysfs_dir" ]
}

set_channel_state() {
	local letter="$1" state="$2" letter_u sysfs_dir max_brightness
	letter_u=$(printf '%s' "$letter" | tr '[:lower:]' '[:upper:]')
	eval "sysfs_dir=\${LED_SYSFS_${letter_u}:-}"
	if [ -n "$sysfs_dir" ]; then
		[ -w "$sysfs_dir/trigger" ] && printf 'none\n' >"$sysfs_dir/trigger"
		case "$state" in
			on)
				max_brightness=$(cat "$sysfs_dir/max_brightness" 2>/dev/null)
				case "$max_brightness" in
					'' | *[!0-9]*) max_brightness=255 ;;
				esac
				printf '%s\n' "$max_brightness" >"$sysfs_dir/brightness"
				;;
			off)
				printf '0\n' >"$sysfs_dir/brightness"
				;;
			*) return 0 ;;
		esac
		return 0
	fi
	return 0
}

resolve_targets() {
	local letter="$1"
	TARGET_LIST=""
	case "$letter" in
		off)
			return 0
			;;
		'')
			return 1
			;;
	esac
	if channel_defined "$letter"; then
		TARGET_LIST="$letter"
		return 0
	fi
	case "$letter" in
		r | g | b)
			TARGET_LIST="$letter"
			;;
		y)
			TARGET_LIST="r g"
			;;
		c)
			TARGET_LIST="g b"
			;;
		m | p)
			TARGET_LIST="r b"
			;;
		w)
			TARGET_LIST="r g b"
			;;
		*)
			return 1
			;;
	esac
	return 0
}

apply_targets() {
	local target missing=0 letter state
	for target in $TARGET_LIST; do
		if ! channel_defined "$target"; then
			missing=1
		fi
	done
	[ "$missing" -eq 0 ] || echo -c 142 -e "One or more LED channels missing for requested color" >&2
	for letter in $LED_LETTERS; do
		state="off"
		for target in $TARGET_LIST; do
			if [ "$letter" = "$target" ]; then
				state="on"
				break
			fi
		done
		set_channel_state "$letter" "$state"
	done
}

discover_leds() {
	discover_from_sysfs
}

[ $# -eq 1 ] || show_help

discover_leds

if [ "$CHANNEL_COUNT" -eq 0 ]; then
	echo -c 160 -e "No LED channels found" >&2
	exit 1
fi

arg=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
case "$arg" in
	-h | --help | help | '') show_help ;;
	off | 0) color="off" ;;
	*) color=$(printf '%s' "$arg" | cut -c1) ;;
esac

resolve_targets "$color" || {
	echo -c 160 -e "Unsupported color '$1'" >&2
	exit 1
}

apply_targets

exit 0
