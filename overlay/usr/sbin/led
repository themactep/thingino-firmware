#!/bin/sh
# LED controller using Linux LED class by color first-letter
# (r, g, b, y, v, c, m, w, p).

LEDS_CLASS_ROOT="/sys/class/leds"
LED_LETTERS=""
CHANNEL_COUNT=0

show_help() {
	echo "Usage: $0 <color|off>
Colors, use the first letter:
  r - red
  g - green
  b - blue
  y - yellow
  v - violet
  c - cyan
  m - magenta
  w - white
  p - purple
" >&2
	exit 1
}

letter_in_list() {
	case " $LED_LETTERS " in
		*" $1 "*) return 0 ;;
		*) return 1 ;;
	esac
}

word_to_letter() {
	case "$1" in
		red | r) echo r ;;
		green | g) echo g ;;
		blue | b) echo b ;;
		yellow | y) echo y ;;
		violet | v) echo v ;;
		cyan | c) echo c ;;
		magenta | m) echo m ;;
		white | w) echo w ;;
		purple | p) echo p ;;
		*) return 1 ;;
	esac
}

resolve_letter_from_name() {
	local name base token letter
	name=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
	base=${name##*:}
	for token in $(printf '%s' "$base" | tr '._-' '   '); do
		letter=$(word_to_letter "$token" 2>/dev/null) || continue
		echo "$letter"
		return 0
	done
	letter=$(word_to_letter "${base#led_}" 2>/dev/null) && {
		echo "$letter"
		return 0
	}
	letter=$(word_to_letter "${base#led-}" 2>/dev/null) && {
		echo "$letter"
		return 0
	}
	case "$base" in
		[rgbymcvwp]) echo "$base" ;;
		*) return 1 ;;
	esac
}

register_channel() {
	local letter="$1" class_path="$2" upper existed=1
	[ -n "$letter" ] || return 1
	[ -n "$class_path" ] || return 1
	[ -d "$class_path" ] || return 1
	[ -w "$class_path/brightness" ] || return 1
	upper=$(printf '%s' "$letter" | tr '[:lower:]' '[:upper:]')
	eval "LED_SYSFS_${upper}='$class_path'"
	if ! letter_in_list "$letter"; then
		LED_LETTERS="$LED_LETTERS $letter"
		existed=0
	fi
	[ "$existed" -eq 0 ] && CHANNEL_COUNT=$((CHANNEL_COUNT + 1))
}

channel_defined() {
	local letter_u sysfs
	letter_u=$(printf '%s' "$1" | tr '[:lower:]' '[:upper:]')
	eval "sysfs=\${LED_SYSFS_${letter_u}:-}"
	[ -n "$sysfs" ] && [ -d "$sysfs" ]
}

set_channel_state() {
	local letter="$1" state="$2" letter_u level sysfs max
	letter_u=$(printf '%s' "$letter" | tr '[:lower:]' '[:upper:]')
	eval "sysfs=\${LED_SYSFS_${letter_u}:-}"
	[ -n "$sysfs" ] || return 0
	[ -d "$sysfs" ] || return 0
	case "$state" in
		on)
			max=1
			[ -r "$sysfs/max_brightness" ] && max=$(cat "$sysfs/max_brightness" 2>/dev/null)
			level=${max:-1}
			;;
		off)
			level=0
			;;
		*) return 0 ;;
	esac
	[ -w "$sysfs/trigger" ] && echo none >"$sysfs/trigger" 2>/dev/null
	[ -w "$sysfs/brightness" ] && echo "$level" >"$sysfs/brightness" 2>/dev/null
}

resolve_targets() {
	local letter="$1"
	TARGET_LIST=""
	case "$letter" in
		off)
			return 0
			;;
		'')
			return 1
			;;
	esac
	if channel_defined "$letter"; then
		TARGET_LIST="$letter"
		return 0
	fi
	case "$letter" in
		r | g | b)
			TARGET_LIST="$letter"
			;;
		y)
			TARGET_LIST="r g"
			;;
		c)
			TARGET_LIST="g b"
			;;
		m | p | v)
			TARGET_LIST="r b"
			;;
		w)
			TARGET_LIST="r g b"
			;;
		*)
			return 1
			;;
	esac
	return 0
}

apply_targets() {
	local target missing=0 letter state
	for target in $TARGET_LIST; do
		if ! channel_defined "$target"; then
			missing=1
		fi
	done
	[ "$missing" -eq 0 ] || echo -c 142 -e "One or more LED channels missing for requested color" >&2
	for letter in $LED_LETTERS; do
		state="off"
		for target in $TARGET_LIST; do
			if [ "$letter" = "$target" ]; then
				state="on"
				break
			fi
		done
		set_channel_state "$letter" "$state"
	done
}

discover_leds() {
	local path base letter
	[ -d "$LEDS_CLASS_ROOT" ] || return 0
	for path in "$LEDS_CLASS_ROOT"/*; do
		[ -d "$path" ] || continue
		base=${path##*/}
		letter=$(resolve_letter_from_name "$base" 2>/dev/null) || continue
		channel_defined "$letter" && continue
		register_channel "$letter" "$path"
	done
}

[ $# -eq 1 ] || show_help

discover_leds

if [ "$CHANNEL_COUNT" -eq 0 ]; then
	echo -c 160 -e "No LED class channels found" >&2
	exit 1
fi

arg=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
case "$arg" in
	-h | --help | help | '') show_help ;;
	off | 0) color="off" ;;
	*) color=$(printf '%s' "$arg" | cut -c1) ;;
esac

resolve_targets "$color" || {
	echo -c 160 -e "Unsupported color '$1'" >&2
	exit 1
}

apply_targets

exit 0
