#!/bin/sh

show_help() {
	echo "Usage: $0 <type> <mode> [pin#]
Where:
	type	ir | ir850 | ir940 | white | flood
	mode	on | off | toggle | read | gpio
" >&2
	exit 1
}

[ "$#" -lt 1 ] && show_help

# set parameters from cli, if empty
[ -z "$type" ] && type="$1"
[ -z "$mode" ] && mode="${2:-read}"

get_config_pin() {
	local type="$1"
	jct /etc/thingino.json get "gpio.$type.pin" 2>/dev/null ||
		jct /etc/thingino.json get "gpio.$type" 2>/dev/null ||
		get_dt_pin "$type"
}

get_config_active_low() {
	local type="$1"
	jct /etc/thingino.json get "gpio.$type.active_low" 2>/dev/null ||
		get_dt_active_low "$type" ||
		echo "false"
}

set_config_pin() {
	local type="$1"
	local pin="$2"
	jct /etc/thingino.json set "gpio.$type.pin" "$pin" 2>/dev/null
}

dt_read_u32() {
	local prop="$1" path="/proc/device-tree/thingino_ir/$prop" bytes
	[ -r "$path" ] || return 1
	bytes=$(od -An -N4 -tx1 "$path" 2>/dev/null | tr -d ' \n')
	[ "${#bytes}" -eq 8 ] || return 1
	printf '%d\n' "$((16#$bytes))"
}

get_dt_pin() {
	local type="$1" prop
	case "$type" in
		ir850) prop="ir850-pin" ;;
		ir940) prop="ir940-pin" ;;
		white | flood) prop="white-pin" ;;
		*) return 1 ;;
	esac
	dt_read_u32 "$prop"
}

get_dt_active_low() {
	local type="$1" prop value
	case "$type" in
		ir850) prop="ir850-active-low" ;;
		ir940) prop="ir940-active-low" ;;
		white | flood) prop="white-active-low" ;;
		*) return 1 ;;
	esac
	value=$(dt_read_u32 "$prop") || return 1
	if [ "$value" -eq 1 ]; then
		echo "true"
	else
		echo "false"
	fi
}

case "$type" in
	ir)
		pin=$(get_config_pin ir850)
		[ -z "$pin" ] && pin=$(get_config_pin ir940)
		if [ -z "$pin" ]; then
			echo -c 160 -e "GPIO pins for either IR lights are not defined" >&2
			exit 1
		fi
		;;
	ir850 | ir940 | white | flood)
		pin=$(get_config_pin "$type")
		if [ -z "$pin" ] && [ "gpio" != "$mode" ]; then
			echo -c 160 -e "GPIO pin for $type light is not defined" >&2
			exit 1
		fi
		;;
	*)
		echo -c 160 -e "Unknown light type $type" >&2
		show_help
		;;
esac

if [ "true" = "$(get_config_active_low "$type")" ]; then
	pin_on=0
	pin_off=1
else
	pin_on=1
	pin_off=0
fi

case "$mode" in
	0 | off)
		gpio set "$pin" "$pin_off"
		;;
	1 | on)
		gpio set "$pin" "$pin_on"
		;;
	~ | toggle)
		gpio toggle "$pin"
		;;
	\? | read | status)
		if [ "$(gpio value $pin | tr -d '\n')" = "$pin_on" ]; then
			echo -n "1"
		else
			echo -n "0"
		fi
		;;
	gpio | pin)
		mode="gpio"
		new_pin="$3"
		if [ -n "$new_pin" ]; then
			set_config_pin "$type" "$new_pin"
		else
			pin=$(get_config_pin "$type")
			if [ -z "$pin" ]; then
				echo -c 160 -e "GPIO pin is missing" >&2
				show_help
			else
				echo "$pin"
			fi
		fi
		;;
	*)
		echo -c 160 -e "Error: Unknown mode" >&2
		show_help
		;;
esac

exit 0
