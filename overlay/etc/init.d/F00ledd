#!/bin/sh

reset_kernel_led_triggers() {
	local path
	for path in /sys/class/leds/led_*; do
		[ -w "$path/trigger" ] && printf 'none\n' >"$path/trigger"
	done
}

start() {
	echo -c 15 "Using kernel LED pipeline"
	return 0
}

stop() {
	echo -c 15 "Resetting LED triggers"
	reset_kernel_led_triggers
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		stop
		start
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
		;;
esac
