#!/bin/sh
# shellcheck disable=SC3043

start() {
	echo -c 15 "Starting network"
	if [ -f /run/wlan_ap_mode ] || [ -f /run/portal_mode ]; then
		echo -c 160 -e "WiFi in AP/portal mode, skipping network bring-up" >&2
		# Ensure loopback is up (normally done by ifup -a)
		ip addr add 127.0.0.1/8 dev lo 2>/dev/null || true
		ip link set lo up 2>/dev/null || true
		exit 0
	fi

	local toggle
	toggle=$(jct /etc/thingino.json get gpio.eth.toggle 2>/dev/null)
	if [ "true" = "$toggle" ]; then
		local pin active low high
		pin=$(jct /etc/thingino.json get gpio.eth.pin 2>/dev/null)
		active=$(jct /etc/thingino.json get gpio.eth.active_low 2>/dev/null)
		if [ "true" = "$active" ]; then
			low=1
			high=0
		else
			low=0
			high=1
		fi
		gpio set $pin $low
		sleep 0.5
		gpio set $pin $high
	else
		echo -c 142 -e "Ethernet GPIO does not need a toggle" >&2
	fi

	ifup -v -a
}

stop() {
	echo -c 15 "Stopping network"

	ifdown -v -a
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		stop
		sleep 1
		start
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
		;;
esac

exit 0
