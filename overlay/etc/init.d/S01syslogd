#!/bin/sh

json_get() {
	local key="$1" value="$2"
	jct /etc/thingino.json get "$key" 2>/dev/null || printf '%s' "$value"
}

DAEMON="/sbin/syslogd"
BASE_DAEMON_ARGS="-n -C64 -S -t -D"
RSYSLOG_CONFIG_DOMAIN="rsyslog"

# -n              Run in foreground
# -R HOST[:PORT]  Log to HOST:PORT (default PORT:514)
# -L              Log locally and via network (default is network only if -R)
# -C[size_kb]     Log to shared mem buffer (use logread to read it)
# -O FILE         Log to FILE (default: /var/log/messages, stdout if -)
# -s SIZE         Max size (KB) before rotation (default 200KB, 0=off)
# -b N            N rotated logs to keep (default 1, max 99, 0=purge)
# -l N            Log only messages more urgent than prio N (1-8)
# -S              Smaller output
# -t              Strip client-generated timestamps
# -D              Drop duplicates

PIDFILE="/run/syslogd.pid"

start_daemon() {
	start-stop-daemon -S -b -m -p "$PIDFILE" -x "$DAEMON" -- "$@"
}

stop_daemon() {
	start-stop-daemon -K -p "$PIDFILE" -x "$DAEMON"
	status=$?
	if [ "$status" -ne 0 ]; then
		return "$status"
	fi

	while [ -f "$PIDFILE" ] && start-stop-daemon -K -t -p "$PIDFILE" -x "$DAEMON"; do
		sleep 0.1
	done

	rm -f "$PIDFILE"
	return 0
}

start() {
	echo -c 15 "Starting syslogd"
	daemon_args="$BASE_DAEMON_ARGS"

	rsyslog_enabled=$(json_get rsyslog.enabled "false")
	rsyslog_host=$(json_get rsyslog.host "$rsyslog_host")
	rsyslog_port=$(json_get rsyslog.port 514)
	rsyslog_file=$(json_get rsyslog.file "false")
	rsyslog_local=$(json_get rsyslog.local "$rsyslog_file")

	if [ -z "$rsyslog_host" ]; then
		echo "Remote logging not configured"
	elif [ "true" != "$rsyslog_enabled" ]; then
		echo "Remote logging disabled"
	else
		echo "Adding remote logging to $rsyslog_host:${rsyslog_port}"
		daemon_args="$daemon_args -R $rsyslog_host:${rsyslog_port}"
	fi

	if [ "true" = "$rsyslog_local" ] || [ "true" = "$rsyslog_file" ]; then
		echo "Adding local logging"
		daemon_args="$daemon_args -L"
	fi

	# shellcheck disable=SC2086
	start_daemon $daemon_args
}

stop() {
	echo -c 15 "Stopping syslogd"

	stop_daemon
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		stop
		sleep 1
		start
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
		;;
esac

exit 0
