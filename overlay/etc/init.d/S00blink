#!/bin/sh
# Find the first available indicator LED and start blinking.

LEDS_CLASS_ROOT="/sys/class/leds"

find_led_by_color() {
	local color="$1" path base
	[ -d "$LEDS_CLASS_ROOT" ] || return 1
	for path in "$LEDS_CLASS_ROOT"/*; do
		[ -d "$path" ] || continue
		base=${path##*/}
		case "$base" in
			"$color" | "led_$color" | "led-$color" | *:"$color" | *:"led_$color" | *:"led-$color")
				echo "$path"
				return 0
				;;
		esac
	done
	return 1
}

# order: blue, green, white, yellow, violet, red
for color in blue green white yellow violet red b g w y v r; do
	LED_PATH=$(find_led_by_color "$color")
	[ -n "$LED_PATH" ] || continue
	[ -w "$LED_PATH/trigger" ] && echo timer >"$LED_PATH/trigger" 2>/dev/null
	[ -w "$LED_PATH/delay_on" ] && echo 1000 >"$LED_PATH/delay_on" 2>/dev/null
	[ -w "$LED_PATH/delay_off" ] && echo 1000 >"$LED_PATH/delay_off" 2>/dev/null
	exit 0
done

echo -c 160 "No LED indicator found in LED class."
exit 1
